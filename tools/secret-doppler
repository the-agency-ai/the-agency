#!/bin/bash
# secret-doppler - CLI for secrets via Doppler
#
# Manage secrets through Doppler's secret management platform.
#
# Usage:
#   ./tools/secret-doppler <command> [options]
#
# Commands:
#   set <name> <value>          Set a secret
#   get <name>                  Get a secret value (plaintext)
#   list                        List all secrets
#   delete <name>               Delete a secret
#   rotate <name>               Rotate a secret (get current, prompt for new, set, verify)
#   scan                        Scan for leaked secrets in the codebase
#
# Options:
#   --project=<project>         Doppler project name
#   --config=<config>           Doppler config name (e.g., dev, stg, prd)
#   --json                      Output in JSON format
#   --verbose                   Show detailed output
#   -h, --help                  Show this help
#   -v, --version               Show version
#
# Auto-detection:
#   If doppler.yaml exists at repo root, project/config defaults are read from it.
#   If cwd is under apps/<name>/, that name is suggested as the project.
#
# Examples:
#   ./tools/secret-doppler get API_KEY --project=backend --config=dev
#   ./tools/secret-doppler set NEW_SECRET myvalue --project=backend --config=dev
#   ./tools/secret-doppler list --project=backend --config=dev
#   ./tools/secret-doppler delete OLD_SECRET --project=backend --config=dev
#   ./tools/secret-doppler rotate API_KEY --project=backend --config=dev
#   ./tools/secret-doppler scan

set -euo pipefail

# Source log helper for telemetry
SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
if [[ -f "$SCRIPT_DIR/_log-helper" ]]; then
    source "$SCRIPT_DIR/_log-helper"
fi
RUN_ID=$(log_start "secret-doppler" "agency-tool" "$@" 2>/dev/null) || true

# Tool version
TOOL_VERSION="1.0.0-20260329-000001"

# Defaults
VERBOSE=false
JSON_OUTPUT=false
PROJECT=""
CONFIG=""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Logging functions (quiet by default)
log_info() { [[ "$VERBOSE" == "true" ]] && echo -e "${GREEN}[INFO]${NC} $1" || true; }
log_warn() { [[ "$VERBOSE" == "true" ]] && echo -e "${YELLOW}[WARN]${NC} $1" || true; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }  # Always show errors
log_step() { [[ "$VERBOSE" == "true" ]] && echo -e "${BLUE}[STEP]${NC} $1" || true; }
verbose_echo() { [[ "$VERBOSE" == "true" ]] && echo "$@" || true; }

# Detect repo root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Auto-detect project/config from doppler.yaml
auto_detect_defaults() {
    local doppler_yaml="$REPO_ROOT/doppler.yaml"
    if [[ -f "$doppler_yaml" ]]; then
        # Extract setup.project and setup.config from doppler.yaml
        if [[ -z "$PROJECT" ]]; then
            PROJECT=$(grep -E '^\s*project:' "$doppler_yaml" | head -1 | sed 's/.*project:\s*//' | tr -d '"' | tr -d "'" | xargs 2>/dev/null || echo "")
            if [[ -n "$PROJECT" ]]; then
                log_info "Auto-detected project from doppler.yaml: $PROJECT"
            fi
        fi
        if [[ -z "$CONFIG" ]]; then
            CONFIG=$(grep -E '^\s*config:' "$doppler_yaml" | head -1 | sed 's/.*config:\s*//' | tr -d '"' | tr -d "'" | xargs 2>/dev/null || echo "")
            if [[ -n "$CONFIG" ]]; then
                log_info "Auto-detected config from doppler.yaml: $CONFIG"
            fi
        fi
    fi

    # If still no project, try to infer from cwd under apps/
    if [[ -z "$PROJECT" ]]; then
        local cwd
        cwd="$(pwd)"
        if [[ "$cwd" =~ /apps/([^/]+) ]]; then
            PROJECT="${BASH_REMATCH[1]}"
            log_info "Auto-detected project from cwd: $PROJECT"
        fi
    fi
}

# Require Doppler CLI
require_doppler() {
    if ! command -v doppler &>/dev/null; then
        log_error "Doppler CLI not found"
        echo "Install: https://docs.doppler.com/docs/install-cli" >&2
        echo "  brew install dopplerhq/cli/doppler  (macOS)" >&2
        log_end "$RUN_ID" "failure" 1 0 "Doppler CLI not installed" 2>/dev/null || true
        exit 1
    fi
}

# Require --project and --config
require_project_config() {
    if [[ -z "$PROJECT" ]]; then
        log_error "Project required. Use --project=<name> or set up doppler.yaml"
        log_end "$RUN_ID" "failure" 1 0 "Missing project" 2>/dev/null || true
        exit 1
    fi
    if [[ -z "$CONFIG" ]]; then
        log_error "Config required. Use --config=<name> (e.g., dev, stg, prd)"
        log_end "$RUN_ID" "failure" 1 0 "Missing config" 2>/dev/null || true
        exit 1
    fi
}

# Parse global options first
while [[ $# -gt 0 ]]; do
    case $1 in
        --version|-v)
            echo "secret-doppler $TOOL_VERSION"
            log_end "$RUN_ID" "success" 0 0 "Version check" 2>/dev/null || true
            exit 0
            ;;
        --help|-h)
            head -36 "$0" | tail -35 | sed 's/^# //' | sed 's/^#//'
            log_end "$RUN_ID" "success" 0 0 "Help displayed" 2>/dev/null || true
            exit 0
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --json)
            JSON_OUTPUT=true
            shift
            ;;
        --project=*)
            PROJECT="${1#*=}"
            shift
            ;;
        --config=*)
            CONFIG="${1#*=}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

verbose_echo "secret-doppler [run: ${RUN_ID:-none}]"

# Command: set
cmd_set() {
    local name="${1:-}"
    local value="${2:-}"

    if [[ -z "$name" ]]; then
        echo "Usage: secret-doppler set <name> <value> --project=<P> --config=<C>"
        exit 1
    fi

    if [[ -z "$value" ]]; then
        echo "Usage: secret-doppler set <name> <value> --project=<P> --config=<C>"
        exit 1
    fi

    require_project_config
    log_step "Setting secret '$name' in $PROJECT/$CONFIG"

    doppler secrets set "$name" "$value" \
        --project "$PROJECT" \
        --config "$CONFIG" \
        --silent 2>&1

    if [[ $? -eq 0 ]]; then
        echo -e "${GREEN}Secret set: $name${NC}"
    else
        log_error "Failed to set secret: $name"
        log_end "$RUN_ID" "failure" 1 0 "Set failed: $name" 2>/dev/null || true
        exit 1
    fi
}

# Command: get
cmd_get() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo "Usage: secret-doppler get <name> --project=<P> --config=<C>"
        exit 1
    fi

    require_project_config
    log_step "Getting secret '$name' from $PROJECT/$CONFIG"

    local value
    value=$(doppler secrets get "$name" --plain \
        --project "$PROJECT" \
        --config "$CONFIG" 2>/dev/null)

    if [[ $? -ne 0 || -z "$value" ]]; then
        log_error "Secret not found: $name (project=$PROJECT, config=$CONFIG)"
        log_end "$RUN_ID" "failure" 1 0 "Get failed: $name" 2>/dev/null || true
        exit 1
    fi

    if [[ "$JSON_OUTPUT" == "true" ]]; then
        printf '{"name":"%s","value":"%s"}\n' "$name" "$value"
    else
        echo "$value"
    fi
}

# Command: list
cmd_list() {
    require_project_config
    log_step "Listing secrets in $PROJECT/$CONFIG"

    if [[ "$JSON_OUTPUT" == "true" ]]; then
        doppler secrets --json \
            --project "$PROJECT" \
            --config "$CONFIG" 2>/dev/null
    else
        doppler secrets \
            --project "$PROJECT" \
            --config "$CONFIG" 2>/dev/null
    fi

    if [[ $? -ne 0 ]]; then
        log_error "Failed to list secrets (project=$PROJECT, config=$CONFIG)"
        log_end "$RUN_ID" "failure" 1 0 "List failed" 2>/dev/null || true
        exit 1
    fi
}

# Command: delete
cmd_delete() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo "Usage: secret-doppler delete <name> --project=<P> --config=<C>"
        exit 1
    fi

    require_project_config
    log_step "Deleting secret '$name' from $PROJECT/$CONFIG"

    doppler secrets delete "$name" \
        --project "$PROJECT" \
        --config "$CONFIG" \
        --yes 2>&1

    if [[ $? -eq 0 ]]; then
        echo -e "${GREEN}Secret deleted: $name${NC}"
    else
        log_error "Failed to delete secret: $name"
        log_end "$RUN_ID" "failure" 1 0 "Delete failed: $name" 2>/dev/null || true
        exit 1
    fi
}

# Command: rotate
cmd_rotate() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo "Usage: secret-doppler rotate <name> --project=<P> --config=<C>"
        exit 1
    fi

    require_project_config
    log_step "Rotating secret '$name' in $PROJECT/$CONFIG"

    # Get current value
    local current
    current=$(doppler secrets get "$name" --plain \
        --project "$PROJECT" \
        --config "$CONFIG" 2>/dev/null)

    if [[ $? -ne 0 || -z "$current" ]]; then
        log_error "Secret not found: $name (project=$PROJECT, config=$CONFIG)"
        log_end "$RUN_ID" "failure" 1 0 "Rotate failed: secret not found" 2>/dev/null || true
        exit 1
    fi

    verbose_echo "Current value retrieved (${#current} chars)"

    # Prompt for new value
    local new_value
    if [[ -t 0 ]]; then
        read -s -p "Enter new value for $name: " new_value
        echo >&2
    elif [[ -n "${VAULT_PASSPHRASE:-}" ]]; then
        log_error "Cannot rotate interactively without a TTY"
        exit 1
    else
        read -s -p "Enter new value for $name: " new_value < /dev/tty
        echo >&2
    fi

    if [[ -z "$new_value" ]]; then
        log_error "New value cannot be empty"
        exit 1
    fi

    # Set new value
    doppler secrets set "$name" "$new_value" \
        --project "$PROJECT" \
        --config "$CONFIG" \
        --silent 2>&1

    if [[ $? -ne 0 ]]; then
        log_error "Failed to set new value for: $name"
        log_end "$RUN_ID" "failure" 1 0 "Rotate set failed" 2>/dev/null || true
        exit 1
    fi

    # Verify
    local verify
    verify=$(doppler secrets get "$name" --plain \
        --project "$PROJECT" \
        --config "$CONFIG" 2>/dev/null)

    if [[ "$verify" == "$new_value" ]]; then
        echo -e "${GREEN}Secret rotated: $name${NC}"
    else
        log_error "Verification failed after rotation for: $name"
        log_end "$RUN_ID" "failure" 1 0 "Rotate verify failed" 2>/dev/null || true
        exit 1
    fi
}

# Command: scan
cmd_scan() {
    log_step "Scanning for leaked secrets..."

    # Delegate to secrets-scan if available
    if [[ -x "$SCRIPT_DIR/secrets-scan" ]]; then
        "$SCRIPT_DIR/secrets-scan" "$@"
        return $?
    fi

    # Fallback: basic scan using grep patterns
    log_info "Running basic secret scan (install secrets-scan for comprehensive scanning)"

    local found=0
    local patterns=(
        'AKIA[0-9A-Z]{16}'                    # AWS Access Key
        'sk-[a-zA-Z0-9]{48}'                  # OpenAI/Anthropic API Key
        'ghp_[a-zA-Z0-9]{36}'                 # GitHub PAT
        'ghu_[a-zA-Z0-9]{36}'                 # GitHub User Token
        'dp\.pt\.[a-zA-Z0-9]{40,}'            # Doppler Token
        'password\s*[:=]\s*["\x27][^"\x27]+'   # Inline passwords
    )

    for pattern in "${patterns[@]}"; do
        local matches
        matches=$(grep -rn --include="*.ts" --include="*.js" --include="*.json" --include="*.env" --include="*.yaml" --include="*.yml" -E "$pattern" "$REPO_ROOT" 2>/dev/null | grep -v node_modules | grep -v ".git/" | head -20 || true)
        if [[ -n "$matches" ]]; then
            if [[ $found -eq 0 ]]; then
                echo -e "${RED}Potential secrets found:${NC}"
                echo ""
            fi
            echo "$matches"
            found=$((found + 1))
        fi
    done

    if [[ $found -eq 0 ]]; then
        echo -e "${GREEN}No leaked secrets detected${NC}"
    else
        echo ""
        echo -e "${YELLOW}Review the findings above. False positives are possible.${NC}"
        log_end "$RUN_ID" "failure" 1 0 "Secrets found: $found patterns" 2>/dev/null || true
        exit 1
    fi
}

# Main command dispatch
main() {
    trap 'log_end "$RUN_ID" "failure" $? 0 "Unexpected exit" 2>/dev/null || true' EXIT

    require_doppler
    auto_detect_defaults

    COMMAND="${1:-}"
    shift || true

    # Parse remaining command-specific options
    local positional_args=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --project=*)
                PROJECT="${1#*=}"
                shift
                ;;
            --config=*)
                CONFIG="${1#*=}"
                shift
                ;;
            --json)
                JSON_OUTPUT=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            *)
                positional_args+=("$1")
                shift
                ;;
        esac
    done

    case "$COMMAND" in
        set)
            cmd_set "${positional_args[@]}"
            ;;
        get)
            cmd_get "${positional_args[@]}"
            ;;
        list)
            cmd_list "${positional_args[@]}"
            ;;
        delete)
            cmd_delete "${positional_args[@]}"
            ;;
        rotate)
            cmd_rotate "${positional_args[@]}"
            ;;
        scan)
            cmd_scan "${positional_args[@]}"
            ;;
        ""|help|--help|-h)
            head -36 "$0" | tail -35 | sed 's/^# //' | sed 's/^#//'
            trap - EXIT
            log_end "$RUN_ID" "success" 0 0 "Help displayed" 2>/dev/null || true
            exit 0
            ;;
        *)
            log_error "Unknown command: $COMMAND"
            echo "Use: ./tools/secret-doppler --help"
            trap - EXIT
            log_end "$RUN_ID" "failure" 1 0 "Unknown command" 2>/dev/null || true
            exit 1
            ;;
    esac

    trap - EXIT
    verbose_echo "secret-doppler complete"
    echo "✓"
    log_end "$RUN_ID" "success" 0 0 "Command completed: $COMMAND" 2>/dev/null || true
}

main "$@"
