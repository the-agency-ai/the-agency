#!/bin/bash
# DEPRECATED: Use ./tools/msg send instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as message-send.legacy
#
# Old usage: ./tools/message-send --to agent:research --subject "Title" "Body"
# New usage: ./tools/msg send research "Title" "Body"

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# Parse old-style arguments into new-style
TO_TARGET=""
SUBJECT=""
BODY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --to)
            TO_TARGET="$2"
            shift 2
            ;;
        --subject)
            SUBJECT="$2"
            shift 2
            ;;
        --version|-v)
            echo "message-send 2.0.0 (deprecated, use ./tools/msg send)"
            exit 0
            ;;
        *)
            # Remaining positional arg is the body
            BODY="$1"
            shift
            ;;
    esac
done

# Extract agent name from old --to format
# Old: agent:research, all, principal:jordan
AGENT_NAME=""
if [[ "$TO_TARGET" == agent:* ]]; then
    AGENT_NAME="${TO_TARGET#agent:}"
    # Handle comma-separated: just use first
    AGENT_NAME="${AGENT_NAME%%,*}"
elif [[ "$TO_TARGET" == "all" || "$TO_TARGET" == "agents" ]]; then
    # Broadcast
    exec "$SCRIPT_DIR/msg" broadcast "${SUBJECT:-Message}" "${BODY:-}"
    exit $?
else
    # Default to the target as-is
    AGENT_NAME="${TO_TARGET}"
fi

if [[ -z "$AGENT_NAME" || -z "$BODY" ]]; then
    echo "message-send [DEPRECATED] Use: ./tools/msg send <agent> \"subject\" \"body\""
    echo "✗"
    exit 1
fi

exec "$SCRIPT_DIR/msg" send "$AGENT_NAME" "${SUBJECT:-Message}" "$BODY"
