#!/bin/bash
#
# worktree-create — Create a git worktree for parallel agent sessions
#
# Usage: worktree-create <name> [--branch <branch>]
#
# Creates a worktree at .worktrees/<name>/ on branch <name> (or --branch).
# Sets up dev environment if dependencies are detected.
#
# This is a FIRST-CLASS PRIMITIVE in Agency 2.0 — worktree isolation
# enables multiple agent sessions to work in parallel without conflicts.

set -euo pipefail

VERSION="2.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source helpers
if [[ -f "$SCRIPT_DIR/_log-helper" ]]; then
    source "$SCRIPT_DIR/_log-helper"
fi
if [[ -f "$SCRIPT_DIR/_path-resolve" ]]; then
    source "$SCRIPT_DIR/_path-resolve"
fi

# --- Flags ---
show_help() {
    echo "Usage: worktree-create <name> [--branch <branch>]"
    echo ""
    echo "Creates a git worktree at .worktrees/<name>/"
    echo ""
    echo "Options:"
    echo "  --branch <name>   Branch name (default: same as worktree name)"
    echo "  --version         Show version"
    echo "  --help            Show this help"
}

NAME=""
BRANCH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v) echo "worktree-create $VERSION"; exit 0 ;;
        --help|-h) show_help; exit 0 ;;
        --branch) BRANCH="$2"; shift 2 ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) NAME="$1"; shift ;;
    esac
done

if [[ -z "$NAME" ]]; then
    echo "Error: worktree name is required" >&2
    show_help >&2
    exit 1
fi

# Validate name
if ! [[ "$NAME" =~ ^[a-zA-Z][a-zA-Z0-9_-]*$ ]]; then
    echo "Error: name must start with a letter and contain only letters, numbers, hyphens, dashes" >&2
    exit 1
fi

BRANCH="${BRANCH:-$NAME}"
PROJECT_ROOT="${AGENCY_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
WORKTREE_DIR="$PROJECT_ROOT/.worktrees/$NAME"

# Check if worktree already exists
if [[ -d "$WORKTREE_DIR" ]]; then
    echo "Error: worktree '$NAME' already exists at $WORKTREE_DIR" >&2
    exit 1
fi

# Create worktree
echo "Creating worktree: $NAME"
echo "  Branch: $BRANCH"
echo "  Path: .worktrees/$NAME/"

mkdir -p "$PROJECT_ROOT/.worktrees"

# Create branch + worktree (from current HEAD)
if git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
    # Branch exists — use it
    git -C "$PROJECT_ROOT" worktree add "$WORKTREE_DIR" "$BRANCH"
else
    # Create new branch from HEAD
    git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_DIR"
fi

# Install dependencies if detected
if [[ -f "$WORKTREE_DIR/package.json" ]]; then
    echo "Installing dependencies..."
    if [[ -f "$WORKTREE_DIR/pnpm-lock.yaml" ]]; then
        (cd "$WORKTREE_DIR" && pnpm install --frozen-lockfile 2>/dev/null) || true
    elif [[ -f "$WORKTREE_DIR/bun.lockb" ]] || [[ -f "$WORKTREE_DIR/bun.lock" ]]; then
        (cd "$WORKTREE_DIR" && bun install 2>/dev/null) || true
    elif [[ -f "$WORKTREE_DIR/yarn.lock" ]]; then
        (cd "$WORKTREE_DIR" && yarn install --frozen-lockfile 2>/dev/null) || true
    elif [[ -f "$WORKTREE_DIR/package-lock.json" ]]; then
        (cd "$WORKTREE_DIR" && npm ci 2>/dev/null) || true
    fi
fi

echo ""
echo "Worktree '$NAME' created successfully!"
echo ""
echo "To work in it:"
echo "  cd $WORKTREE_DIR && claude"
