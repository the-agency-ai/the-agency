#!/bin/bash
# DEPRECATED: Use ./tools/msg send instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as collaborate.legacy
#
# Old usage: ./tools/collaborate "target-agent" "subject" "description"
# New usage: ./tools/msg send <agent> "subject" "body" --tag collaboration

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

TARGET=""
SUBJECT=""
BODY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v)
            echo "collaborate 2.0.0 (deprecated, use ./tools/msg send)"
            exit 0
            ;;
        --verbose)
            shift
            ;;
        *)
            if [[ -z "$TARGET" ]]; then
                TARGET="$1"
            elif [[ -z "$SUBJECT" ]]; then
                SUBJECT="$1"
            elif [[ -z "$BODY" ]]; then
                BODY="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$TARGET" || -z "$SUBJECT" || -z "$BODY" ]]; then
    echo "collaborate [DEPRECATED] Use: ./tools/msg send <agent> \"subject\" \"body\""
    echo "✗"
    exit 1
fi

exec "$SCRIPT_DIR/msg" send "$TARGET" "$SUBJECT" "$BODY" --tag collaboration
