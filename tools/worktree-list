#!/bin/bash
#
# worktree-list — List all git worktrees with status
#
# Usage: worktree-list [--json]
#
# Shows all worktrees, their branches, and status (clean/dirty, ahead/behind).

set -euo pipefail

VERSION="2.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -f "$SCRIPT_DIR/_log-helper" ]]; then
    source "$SCRIPT_DIR/_log-helper"
fi

# --- Flags ---
JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v) echo "worktree-list $VERSION"; exit 0 ;;
        --help|-h) echo "Usage: worktree-list [--json]"; exit 0 ;;
        --json) JSON_OUTPUT=true; shift ;;
        *) shift ;;
    esac
done

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Get worktree list
WORKTREES=$(git -C "$PROJECT_ROOT" worktree list --porcelain 2>/dev/null)

if [[ -z "$WORKTREES" ]]; then
    echo "No worktrees found."
    exit 0
fi

if [[ "$JSON_OUTPUT" == "true" ]]; then
    # JSON output for programmatic use
    echo "["
    FIRST=true
    while IFS= read -r line; do
        if [[ "$line" =~ ^worktree\ (.+) ]]; then
            WT_PATH="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^HEAD\ (.+) ]]; then
            WT_HEAD="${BASH_REMATCH[1]:0:7}"
        elif [[ "$line" =~ ^branch\ refs/heads/(.+) ]]; then
            WT_BRANCH="${BASH_REMATCH[1]}"
        elif [[ -z "$line" ]]; then
            if [[ -n "${WT_PATH:-}" ]]; then
                DIRTY=$(git -C "$WT_PATH" status --porcelain 2>/dev/null | head -1)
                STATUS="clean"
                [[ -n "$DIRTY" ]] && STATUS="dirty"

                [[ "$FIRST" == "true" ]] || echo ","
                FIRST=false
                printf '  {"path": "%s", "branch": "%s", "head": "%s", "status": "%s"}' \
                    "$WT_PATH" "${WT_BRANCH:-detached}" "${WT_HEAD:-unknown}" "$STATUS"
            fi
            WT_PATH="" WT_HEAD="" WT_BRANCH=""
        fi
    done <<< "$WORKTREES"
    echo ""
    echo "]"
else
    # Human-readable table
    printf "%-30s %-25s %-8s %-7s\n" "WORKTREE" "BRANCH" "HEAD" "STATUS"
    printf "%-30s %-25s %-8s %-7s\n" "--------" "------" "----" "------"

    while IFS= read -r line; do
        if [[ "$line" =~ ^worktree\ (.+) ]]; then
            WT_PATH="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^HEAD\ (.+) ]]; then
            WT_HEAD="${BASH_REMATCH[1]:0:7}"
        elif [[ "$line" =~ ^branch\ refs/heads/(.+) ]]; then
            WT_BRANCH="${BASH_REMATCH[1]}"
        elif [[ -z "$line" ]]; then
            if [[ -n "${WT_PATH:-}" ]]; then
                # Shorten path for display
                SHORT_PATH="${WT_PATH#$PROJECT_ROOT/}"
                [[ "$SHORT_PATH" == "$WT_PATH" ]] && SHORT_PATH="(main)"

                DIRTY=$(git -C "$WT_PATH" status --porcelain 2>/dev/null | head -1)
                STATUS="clean"
                [[ -n "$DIRTY" ]] && STATUS="dirty"

                printf "%-30s %-25s %-8s %-7s\n" \
                    "$SHORT_PATH" "${WT_BRANCH:-detached}" "${WT_HEAD:-?}" "$STATUS"
            fi
            WT_PATH="" WT_HEAD="" WT_BRANCH=""
        fi
    done <<< "$WORKTREES"
fi
