#!/bin/bash
# DEPRECATED: Use ./tools/msg send --ref instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as collaboration-respond.legacy
#
# Old usage: ./tools/collaboration-respond "path/to/file.md" "response text"
# New usage: ./tools/msg send <agent> "Re: subject" "body" --ref <msg-id>

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

echo "collaboration-respond [DEPRECATED]"
echo "Use: ./tools/msg send <agent> \"Re: subject\" \"body\" --ref <msg-id>"
echo ""
echo "The file-based collaboration system has been replaced by unified messaging."
echo "To reply to a message, use: ./tools/msg send <agent> \"subject\" \"body\" --ref <msg-id>"
echo "To see threads: ./tools/msg thread <msg-id>"
echo "✗"
exit 1
