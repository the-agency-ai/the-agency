#!/bin/bash
# Unified messaging tool
#
# Usage: ./tools/msg <command> [options]
#
# Commands:
#   send <agent> "subject" "body"           Send direct message
#   broadcast "subject" "body"              Broadcast to all agents
#   read                                    Show unread messages
#   read --all                              Show all messages
#   read --from <agent>                     Filter by sender
#   read --type broadcast                   Show only broadcasts
#   thread <msg-id>                         Show message chain
#   ack <msg-id>                            Mark as read
#
# Options:
#   --ref <msg-id>    Link reply to a message
#   --tag <tag>       Add tag (can repeat)
#   --format json     Output as JSON
#   --agent <name>    Override agent identity

set -euo pipefail

# Source log helper for telemetry
SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
if [[ -f "$SCRIPT_DIR/_log-helper" ]]; then
    source "$SCRIPT_DIR/_log-helper"
fi
RUN_ID=$(log_start "msg" "agency-tool" "$@" 2>/dev/null) || true

# Configuration
AGENCY_SERVICE_URL="${AGENCY_SERVICE_URL:-http://localhost:3141}"
FROM_AGENT="${AGENTNAME:-${AGENT_NAME:-captain}}"

# Parse command
COMMAND="${1:-read}"
shift 2>/dev/null || true

# Check service availability
check_service() {
    curl -s --connect-timeout 2 "${AGENCY_SERVICE_URL}/health" >/dev/null 2>&1
}

# Main function
main() {
    trap 'log_end "$RUN_ID" "failure" $? 0 "Unexpected exit" 2>/dev/null || true' EXIT

    echo "msg [run: ${RUN_ID:-none}]"

    if ! check_service; then
        echo "Service not available at $AGENCY_SERVICE_URL"
        echo "Start service: ./tools/agency-service start"
        echo "✗"
        trap - EXIT
        log_end "$RUN_ID" "failure" 1 0 "Service unavailable" 2>/dev/null || true
        exit 1
    fi

    case "$COMMAND" in
        send)
            cmd_send "$@"
            ;;
        broadcast)
            cmd_broadcast "$@"
            ;;
        read)
            cmd_read "$@"
            ;;
        thread)
            cmd_thread "$@"
            ;;
        ack)
            cmd_ack "$@"
            ;;
        *)
            echo "Unknown command: $COMMAND"
            echo "Usage: ./tools/msg {send|broadcast|read|thread|ack}"
            echo "✗"
            trap - EXIT
            log_end "$RUN_ID" "failure" 1 0 "Unknown command" 2>/dev/null || true
            exit 1
            ;;
    esac

    trap - EXIT
    log_end "$RUN_ID" "success" 0 0 "Completed" 2>/dev/null || true
}

cmd_send() {
    local to_agent=""
    local subject=""
    local body=""
    local ref_id=""
    local tags="[]"
    local tag_list=()
    local agent_override=""

    # Parse positional args and options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ref)
                ref_id="$2"
                shift 2
                ;;
            --tag)
                tag_list+=("$2")
                shift 2
                ;;
            --agent)
                agent_override="$2"
                shift 2
                ;;
            *)
                if [[ -z "$to_agent" ]]; then
                    to_agent="$1"
                elif [[ -z "$subject" ]]; then
                    subject="$1"
                elif [[ -z "$body" ]]; then
                    body="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$to_agent" || -z "$subject" || -z "$body" ]]; then
        echo "Usage: ./tools/msg send <agent> \"subject\" \"body\" [--ref <id>] [--tag <tag>]"
        echo "✗"
        exit 1
    fi

    local from="${agent_override:-$FROM_AGENT}"

    # Build tags JSON array
    if [[ ${#tag_list[@]} -gt 0 ]]; then
        tags=$(printf '%s\n' "${tag_list[@]}" | jq -R . | jq -s .)
    fi

    # Build JSON payload
    local payload
    payload=$(jq -n \
        --arg from "$from" \
        --arg to "$to_agent" \
        --arg subject "$subject" \
        --arg body "$body" \
        --arg ref "$ref_id" \
        --argjson tags "$tags" \
        '{
            fromAgent: $from,
            toAgent: $to,
            subject: $subject,
            body: $body,
            tags: $tags
        } + (if $ref != "" then {referenceId: $ref} else {} end)')

    local response
    response=$(curl -s -X POST "${AGENCY_SERVICE_URL}/api/message/send" \
        -H "Content-Type: application/json" \
        -d "$payload")

    if echo "$response" | jq -e '.id' >/dev/null 2>&1; then
        echo "Sent to $to_agent: $subject"
        echo "✓"
    else
        local err
        err=$(echo "$response" | jq -r '.message // "Unknown error"' 2>/dev/null)
        echo "Failed: $err"
        echo "✗"
        exit 1
    fi
}

cmd_broadcast() {
    local subject=""
    local body=""
    local ref_id=""
    local tags="[]"
    local tag_list=()
    local agent_override=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ref)
                ref_id="$2"
                shift 2
                ;;
            --tag)
                tag_list+=("$2")
                shift 2
                ;;
            --agent)
                agent_override="$2"
                shift 2
                ;;
            *)
                if [[ -z "$subject" ]]; then
                    subject="$1"
                elif [[ -z "$body" ]]; then
                    body="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$subject" || -z "$body" ]]; then
        echo "Usage: ./tools/msg broadcast \"subject\" \"body\" [--tag <tag>]"
        echo "✗"
        exit 1
    fi

    local from="${agent_override:-$FROM_AGENT}"

    if [[ ${#tag_list[@]} -gt 0 ]]; then
        tags=$(printf '%s\n' "${tag_list[@]}" | jq -R . | jq -s .)
    fi

    local payload
    payload=$(jq -n \
        --arg from "$from" \
        --arg subject "$subject" \
        --arg body "$body" \
        --arg ref "$ref_id" \
        --argjson tags "$tags" \
        '{
            fromAgent: $from,
            subject: $subject,
            body: $body,
            tags: $tags
        } + (if $ref != "" then {referenceId: $ref} else {} end)')

    local response
    response=$(curl -s -X POST "${AGENCY_SERVICE_URL}/api/message/broadcast" \
        -H "Content-Type: application/json" \
        -d "$payload")

    if echo "$response" | jq -e '.id' >/dev/null 2>&1; then
        echo "Broadcast: $subject"
        echo "✓"
    else
        local err
        err=$(echo "$response" | jq -r '.message // "Unknown error"' 2>/dev/null)
        echo "Failed: $err"
        echo "✗"
        exit 1
    fi
}

cmd_read() {
    local show_all=false
    local from_filter=""
    local type_filter=""
    local format="table"
    local agent_override=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)
                show_all=true
                shift
                ;;
            --from)
                from_filter="$2"
                shift 2
                ;;
            --type)
                type_filter="$2"
                shift 2
                ;;
            --format)
                format="$2"
                shift 2
                ;;
            --agent)
                agent_override="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    local agent="${agent_override:-$FROM_AGENT}"

    if [[ "$show_all" == "true" ]]; then
        # List all messages for this agent
        local query="limit=50"
        [[ -n "$from_filter" ]] && query="${query}&fromAgent=${from_filter}"
        [[ -n "$type_filter" ]] && query="${query}&type=${type_filter}"

        local response
        response=$(curl -s "${AGENCY_SERVICE_URL}/api/message/list?${query}")

        if [[ "$format" == "json" ]]; then
            echo "$response" | jq '.messages'
        else
            format_messages "$response"
        fi
    else
        # Show unread only
        local response
        response=$(curl -s "${AGENCY_SERVICE_URL}/api/message/unread/${agent}")

        local count
        count=$(echo "$response" | jq -r '.unreadCount // 0')

        if [[ "$count" == "0" ]]; then
            echo "No unread messages"
        else
            if [[ "$format" == "json" ]]; then
                echo "$response" | jq '.messages'
            else
                echo "$count unread message(s):"
                echo ""
                format_unread "$response"
            fi
        fi
    fi
    echo "✓"
}

format_messages() {
    local json="$1"
    echo "$json" | jq -r '.messages[] | "[\(.type)] \(.fromAgent) → \(.toAgent // "all") | \(.subject) (\(.id | .[0:8]))"'
}

format_unread() {
    local json="$1"
    echo "$json" | jq -r '.messages[] | "  [\(.type | if . == "direct" then "DM" else "BC" end)] \(.fromAgent): \(.subject)\n    \(.body | .[0:80])\n    id: \(.id | .[0:8])...\n"'
}

cmd_thread() {
    local msg_id="${1:-}"

    if [[ -z "$msg_id" ]]; then
        echo "Usage: ./tools/msg thread <msg-id>"
        echo "✗"
        exit 1
    fi

    local response
    response=$(curl -s "${AGENCY_SERVICE_URL}/api/message/thread/${msg_id}")

    if echo "$response" | jq -e '.error' >/dev/null 2>&1; then
        local err
        err=$(echo "$response" | jq -r '.message // "Not found"')
        echo "Failed: $err"
        echo "✗"
        exit 1
    fi

    # Display root message
    echo "=== Thread ==="
    echo "$response" | jq -r '.root | "[\(.type)] \(.fromAgent) → \(.toAgent // "all")\nSubject: \(.subject)\n\(.body)\n---"'

    # Display replies
    local reply_count
    reply_count=$(echo "$response" | jq '.replies | length')

    if [[ "$reply_count" -gt 0 ]]; then
        echo ""
        echo "Replies ($reply_count):"
        echo "$response" | jq -r '.replies[] | "  \(.fromAgent): \(.body | .[0:120])"'
    fi
    echo "✓"
}

cmd_ack() {
    local msg_id="${1:-}"
    local agent_override=""

    if [[ -z "$msg_id" ]]; then
        # Check for --agent flag after the ID
        shift 2>/dev/null || true
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent)
                    agent_override="$2"
                    shift 2
                    ;;
                *)
                    msg_id="$1"
                    shift
                    ;;
            esac
        done
    fi

    if [[ -z "$msg_id" ]]; then
        echo "Usage: ./tools/msg ack <msg-id>"
        echo "✗"
        exit 1
    fi

    local agent="${agent_override:-$FROM_AGENT}"

    local response
    response=$(curl -s -X POST "${AGENCY_SERVICE_URL}/api/message/read/${msg_id}" \
        -H "Content-Type: application/json" \
        -d "{\"agentName\": \"$agent\"}")

    if echo "$response" | jq -e '.success' >/dev/null 2>&1; then
        echo "Acknowledged: ${msg_id:0:8}..."
        echo "✓"
    else
        echo "Failed to acknowledge message"
        echo "✗"
        exit 1
    fi
}

main "$@"
