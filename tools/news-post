#!/bin/bash
# DEPRECATED: Use ./tools/msg broadcast instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as news-post.legacy
#
# Old usage: ./tools/news-post "Subject" "Body"
# New usage: ./tools/msg broadcast "Subject" "Body"

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

SUBJECT=""
BODY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v)
            echo "news-post 2.0.0 (deprecated, use ./tools/msg broadcast)"
            exit 0
            ;;
        --verbose)
            shift
            ;;
        *)
            if [[ -z "$SUBJECT" ]]; then
                SUBJECT="$1"
            elif [[ -z "$BODY" ]]; then
                BODY="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$SUBJECT" || -z "$BODY" ]]; then
    echo "news-post [DEPRECATED] Use: ./tools/msg broadcast \"subject\" \"body\""
    echo "✗"
    exit 1
fi

exec "$SCRIPT_DIR/msg" broadcast "$SUBJECT" "$BODY"
