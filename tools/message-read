#!/bin/bash
# DEPRECATED: Use ./tools/msg read instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as message-read.legacy
#
# Old usage: ./tools/message-read [--all] [--count] [--read <id>] [--mark-all-read]
# New usage: ./tools/msg read [--all]

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# Parse old-style arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v)
            echo "message-read 2.0.0 (deprecated, use ./tools/msg read)"
            exit 0
            ;;
        --count)
            # Just show count — use msg read and count output
            exec "$SCRIPT_DIR/msg" read 2>/dev/null | grep -o '[0-9]* unread' || echo "0 unread"
            exit 0
            ;;
        --all)
            exec "$SCRIPT_DIR/msg" read --all
            ;;
        --read)
            exec "$SCRIPT_DIR/msg" ack "$2"
            ;;
        --mark-all-read)
            echo "message-read [DEPRECATED] mark-all-read not supported in new system"
            echo "Use: ./tools/msg ack <msg-id> for individual messages"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

# Default: show unread
exec "$SCRIPT_DIR/msg" read
