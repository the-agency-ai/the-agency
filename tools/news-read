#!/bin/bash
# DEPRECATED: Use ./tools/msg read instead
#
# Wrapper that delegates to the unified messaging tool.
# Original preserved as news-read.legacy
#
# Old usage: ./tools/news-read [--quiet]
# New usage: ./tools/msg read [--type broadcast]

set -euo pipefail

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

QUIET=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version|-v)
            echo "news-read 2.0.0 (deprecated, use ./tools/msg read)"
            exit 0
            ;;
        --quiet)
            QUIET=true
            shift
            ;;
        --verbose)
            shift
            ;;
        *)
            shift
            ;;
    esac
done

# Check if service is available — if not, fall back to legacy
AGENCY_SERVICE_URL="${AGENCY_SERVICE_URL:-http://localhost:3141}"
if ! curl -s --connect-timeout 1 "${AGENCY_SERVICE_URL}/health" >/dev/null 2>&1; then
    # Service not running — fall back to legacy file-based news-read
    if [[ -x "$SCRIPT_DIR/news-read.legacy" ]]; then
        exec "$SCRIPT_DIR/news-read.legacy" "$@"
    fi
    echo "news-read [run: none]"
    echo "Already up to date."
    echo ""
    echo "No unread news messages for agent: ${AGENTNAME:-captain}"
    exit 0
fi

if [[ "$QUIET" == "true" ]]; then
    # Quiet mode: just show unread broadcasts concisely
    AGENT="${AGENTNAME:-${AGENT_NAME:-captain}}"
    RESPONSE=$(curl -s "${AGENCY_SERVICE_URL}/api/message/unread/${AGENT}" 2>/dev/null)
    COUNT=$(echo "$RESPONSE" | jq '[.messages[] | select(.type == "broadcast")] | length' 2>/dev/null || echo 0)
    if [[ "$COUNT" -gt 0 ]]; then
        echo "$RESPONSE" | jq -r '[.messages[] | select(.type == "broadcast")] | .[] | "[\(.fromAgent)] \(.subject): \(.body | .[0:80])"'
    fi
else
    exec "$SCRIPT_DIR/msg" read --type broadcast --all
fi
