#!/bin/bash
# tool-new - Create a new tool from template
#
# Usage:
#   ./claude/tools/tool-create <name> "<description>"
#
# Creates a new tool that:
# - Uses context-efficient logging (1-line output)
# - Logs details to log-service
# - Supports --verbose for immediate output
# - Returns run-id for debugging

set -euo pipefail

# Source log helper for telemetry
SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi
RUN_ID=$(log_start "tool-new" "$@" 2>/dev/null) || true

# Tool version
TOOL_VERSION="1.0.0-20260114-000006"

# Defaults
VERBOSE=false

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
TEMPLATE_FILE="$PROJECT_ROOT/claude/templates/TOOL.sh"
PROVIDER_TEMPLATE_FILE="$PROJECT_ROOT/claude/templates/PROVIDER.sh"
TOOLS_DIR="$PROJECT_ROOT/claude/tools"
BUILD_FILE="$PROJECT_ROOT/claude/data/tool-build-number"

# Provider pattern naming conventions (section -> tool prefix)
# Usage: tool-new --provider=secrets my-backend "My secrets backend"
#   → creates tools/secret-my-backend from PROVIDER.sh template
PROVIDER_PATTERN=""
PYTHON_MODE=false

# Colors
if [[ -f "$SCRIPT_DIR/lib/_colors" ]]; then
    source "$SCRIPT_DIR/lib/_colors"
else
    RED="[0;31m" GREEN="[0;32m" YELLOW="[1;33m" BLUE="[0;34m" NC="[0m"
fi

# Logging functions (quiet by default)
log_info() { [[ "$VERBOSE" == "true" ]] && echo -e "${GREEN}[INFO]${NC} $1" || true; }
log_warn() { [[ "$VERBOSE" == "true" ]] && echo -e "${YELLOW}[WARN]${NC} $1" || true; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }  # Always show errors
log_step() { [[ "$VERBOSE" == "true" ]] && echo -e "${BLUE}[STEP]${NC} $1" || true; }
verbose_echo() { [[ "$VERBOSE" == "true" ]] && echo "$@" || true; }

# Escape sed special characters to prevent injection
escape_sed() {
    printf '%s\n' "$1" | sed 's/[&/\]/\\&/g'
}

# Get next build number (monotonically increasing)
get_next_build() {
    mkdir -p "$(dirname "$BUILD_FILE")"

    if [[ -f "$BUILD_FILE" ]]; then
        local current
        current=$(cat "$BUILD_FILE")
        local next=$((current + 1))
        echo "$next" > "$BUILD_FILE"
        echo "$next"
    else
        echo "1" > "$BUILD_FILE"
        echo "1"
    fi
}

# Main
main() {
    # Trap unexpected exits
    trap 'log_end "$RUN_ID" "failure" $? 0 "Unexpected exit" 2>/dev/null || true' EXIT

    echo "tool-new [run: ${RUN_ID:-none}]"

    # Extract positional args (skip flags)
    local positional=()
    for arg in "$@"; do
        case "$arg" in
            --*) ;; # skip flags
            *) positional+=("$arg") ;;
        esac
    done
    local tool_name="${positional[0]:-}"
    local tool_description="${positional[1]:-A new tool}"

    # Handle --version
    if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
        echo "tool-new $TOOL_VERSION"
        trap - EXIT
        log_end "$RUN_ID" "success" 0 0 "Version displayed" 2>/dev/null || true
        exit 0
    fi

    # Handle flags
    for arg in "$@"; do
        case $arg in
            --verbose)
                VERBOSE=true
                ;;
            --python)
                PYTHON_MODE=true
                ;;
            --provider=*)
                PROVIDER_PATTERN="${arg#--provider=}"
                ;;
        esac
    done

    # Handle --help
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || -z "$tool_name" ]]; then
        echo "tool-new - Create a new tool from template"
        echo ""
        echo "Usage:"
        echo "  ./claude/tools/tool-create <name> \"<description>\""
        echo "  ./claude/tools/tool-create --provider=<pattern> <name> \"<description>\""
        echo ""
        echo "Options:"
        echo "  --provider=<pattern>  Create a provider tool (secrets, terminal, platform, design)"
        echo "  --verbose             Show detailed output"
        echo ""
        echo "Examples:"
        echo "  ./claude/tools/tool-create sync-data \"Sync data between environments\""
        echo "  ./claude/tools/tool-create --python my-tool \"My Python tool\""
        echo "    → creates tools/my-tool from TOOL.py template"
        echo "  ./claude/tools/tool-create --provider=secrets aws \"AWS Secrets Manager provider\""
        echo "    → creates tools/secret-aws"
        trap - EXIT
        log_end "$RUN_ID" "success" 0 0 "Help displayed" 2>/dev/null || true
        exit 1
    fi

    # Validate name
    if [[ ! "$tool_name" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "Tool name must be lowercase, start with letter, contain only letters, numbers, hyphens"
        trap - EXIT
        log_end "$RUN_ID" "failure" 1 0 "Invalid tool name" 2>/dev/null || true
        exit 1
    fi

    # Python mode: use Python template
    local actual_template="$TEMPLATE_FILE"
    if [[ "$PYTHON_MODE" == "true" ]]; then
        actual_template="$PROJECT_ROOT/claude/templates/TOOL.py"
    fi

    # Provider mode: remap tool name and select provider template
    local dispatcher_name=""
    if [[ -n "$PROVIDER_PATTERN" ]]; then
        actual_template="$PROVIDER_TEMPLATE_FILE"
        # Map pattern to tool name prefix and dispatcher
        case "$PROVIDER_PATTERN" in
            secrets)
                tool_name="secret-${tool_name}"
                dispatcher_name="secret"
                ;;
            terminal)
                tool_name="terminal-setup-${tool_name}"
                dispatcher_name="terminal-setup"
                ;;
            platform)
                tool_name="platform-setup-${tool_name}"
                dispatcher_name="platform-setup"
                ;;
            design)
                tool_name="design-${tool_name}"
                dispatcher_name="design"
                ;;
            *)
                log_error "Unknown provider pattern: $PROVIDER_PATTERN"
                log_error "Valid patterns: secrets, terminal, platform, design"
                trap - EXIT
                log_end "$RUN_ID" "failure" 1 0 "Invalid pattern" 2>/dev/null || true
                exit 1
                ;;
        esac
    fi

    # Check if tool already exists (after provider remapping)
    local tool_file="$TOOLS_DIR/$tool_name"
    if [[ -f "$tool_file" ]]; then
        log_error "Tool already exists: $tool_file"
        trap - EXIT
        log_end "$RUN_ID" "failure" 1 0 "Tool already exists" 2>/dev/null || true
        exit 1
    fi

    # Check template exists
    if [[ ! -f "$actual_template" ]]; then
        log_error "Template not found: $actual_template"
        trap - EXIT
        log_end "$RUN_ID" "failure" 1 0 "Template not found" 2>/dev/null || true
        exit 1
    fi

    # Get build number and date
    local build_number
    build_number=$(get_next_build)
    local tool_date
    tool_date=$(date '+%Y%m%d')

    # Generate tool
    log_step "Creating tool: $tool_name"

    # Escape sed special characters to prevent injection
    local tool_name_escaped
    local tool_description_escaped
    local build_number_escaped
    local provider_pattern_escaped
    local dispatcher_name_escaped
    tool_name_escaped=$(escape_sed "$tool_name")
    tool_description_escaped=$(escape_sed "$tool_description")
    build_number_escaped=$(escape_sed "$build_number")
    provider_pattern_escaped=$(escape_sed "${PROVIDER_PATTERN:-}")
    dispatcher_name_escaped=$(escape_sed "${dispatcher_name:-}")

    local tool_date_escaped
    local tool_author_escaped
    tool_date_escaped=$(escape_sed "$(date '+%Y-%m-%d')")
    tool_author_escaped=$(escape_sed "${AGENCY_PRINCIPAL:-${USER:-unknown}}")

    sed \
        -e "s/{{TOOL_NAME}}/$tool_name_escaped/g" \
        -e "s/{{TOOL_DESCRIPTION}}/$tool_description_escaped/g" \
        -e "s/{{BUILD_NUMBER}}/$build_number_escaped/g" \
        -e "s/{{TOOL_DATE}}/$tool_date_escaped/g" \
        -e "s/{{TOOL_AUTHOR}}/$tool_author_escaped/g" \
        -e "s/{{PROVIDER_PATTERN}}/$provider_pattern_escaped/g" \
        -e "s/{{DISPATCHER_NAME}}/$dispatcher_name_escaped/g" \
        "$actual_template" > "$tool_file"

    chmod +x "$tool_file"

    log_info "Created: $tool_file"
    log_info "Build: $build_number"
    verbose_echo ""
    verbose_echo "Next steps:"
    verbose_echo "  1. Edit $tool_file and add your logic"
    verbose_echo "  2. Test with: ./claude/tools/$tool_name --verbose"
    verbose_echo "  3. Test logging: ./claude/tools/$tool_name"

    trap - EXIT
    log_end "$RUN_ID" "success" 0 0 "Created $tool_name" 2>/dev/null || true
}

main "$@"
