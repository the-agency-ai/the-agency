{
  "$schema": "./claude/docs/schemas/registry.schema.json",
  "schema_version": "2.0",
  "protected_paths": [
    "usr/**/*",
    "claude/principals/**/*",
    "tools/local/**/*",
    "claude/agents/captain/backups/**/*",
    "claude/workstreams/housekeeping/sprints/**/*"
  ],
  "components": {
    "core": {
      "version": "2.0.0",
      "description": "Core Agency framework - CLAUDE.md, basic structure, conventions",
      "files": [
        "CLAUDE.md",
        "claude/docs/**/*",
        "claude/config/**/*",
        "claude/agents/templates/**/*"
      ]
    },
    "tools": {
      "version": "2.0.0",
      "description": "Agency CLI and tools",
      "files": [
        "claude/tools/*",
        "claude/tools/lib/*"
      ],
      "dependencies": ["core"]
    },
    "captain": {
      "version": "2.0.0",
      "description": "The Captain agent - your guide to The Agency",
      "files": [
        "claude/agents/captain/**/*"
      ],
      "dependencies": ["core"]
    },
    "housekeeping": {
      "version": "2.0.0",
      "description": "The housekeeping workstream - default workspace",
      "files": [
        "claude/workstreams/housekeeping/**/*"
      ],
      "dependencies": ["core"]
    },
    "agency-service": {
      "version": "1.0.0",
      "description": "Backend service for logging, secrets, and messaging",
      "files": [
        "source/services/agency-service/**/*"
      ],
      "dependencies": ["core"]
    },
    "starter-packs": {
      "version": "1.0.0",
      "description": "Framework-specific conventions (Next.js, React Native, Python, etc.)",
      "files": [
        "claude/starter-packs/**/*"
      ],
      "dependencies": ["core"]
    },
    "skills": {
      "version": "1.0.0",
      "description": "Agent skills - welcome, tutorial, commit, etc.",
      "files": [
        "claude/skills/**/*"
      ],
      "dependencies": ["core"]
    },
    "methodology": {
      "version": "2.0.0",
      "description": "Development methodology - quality gates, work patterns, 1B1 protocol",
      "files": [
        "claude/docs/QUALITY-GATE.md",
        "claude/docs/DEVELOPMENT-METHODOLOGY.md",
        "claude/docs/CODE-REVIEW-LIFECYCLE.md",
        "claude/docs/FEEDBACK-FORMAT.md",
        ".claude/commands/discuss.md"
      ],
      "dependencies": ["core"]
    },
    "worktree-management": {
      "version": "2.0.0",
      "description": "Worktree isolation for parallel agent sessions",
      "files": [
        "claude/tools/worktree-create",
        "claude/tools/worktree-list",
        "claude/tools/worktree-delete"
      ],
      "dependencies": ["core", "tools"]
    },
    "reviewer-agents": {
      "version": "2.0.0",
      "description": "Code review agents - code, design, scorer, security, test",
      "files": [
        "claude/agents/reviewer-code/**/*",
        "claude/agents/reviewer-design/**/*",
        "claude/agents/reviewer-scorer/**/*",
        "claude/agents/reviewer-security/**/*",
        "claude/agents/reviewer-test/**/*",
        "claude/agents/project-manager/**/*"
      ],
      "dependencies": ["core"]
    }
  }
}
