{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/tools/iscp-check"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/tools/collaboration check"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/tools/iscp-check"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/hooks/ref-injector.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/tools/iscp-check"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./claude/tools/*)",
      "Bash(./claude/tools/* *)",
      "Bash(bash ./claude/tools/*)",
      "Glob(.claude/**)",
      "Glob(claude/**)",
      "Glob(usr/**)",
      "Glob(tests/**)",
      "Read(.claude/**)",
      "Read(claude/**)",
      "Read(usr/**)",
      "Read(tests/**)",
      "Bash(sqlite3 */.agency/*/iscp.db *)",
      "Bash(ls */.agency/*)",
      "Bash(ls */.agency/)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git symbolic-ref *)",
      "Bash(git show *)",
      "Bash(git -C * log *)",
      "Bash(git -C * status *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git checkout * -- *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(git reset --soft *)",
      "Bash(git config *)",
      "Bash(chmod +x ./claude/tools/*)",
      "Bash(chmod +x claude/tools/*)",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(unzip -d usr/*:*)",
      "Bash(bats tests/*)",
      "Bash(bats *tests/tools/*)",
      "Bash(npx vitest *)"
    ]
  }
}
