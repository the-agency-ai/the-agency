{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/hooks/ref-injector.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./claude/tools/*:*)",
      "Glob(.claude/**)",
      "Glob(claude/**)",
      "Glob(usr/**)",
      "Bash(./claude/tools/safe-extract*)",
      "Bash(./claude/tools/worktree-sync*)",
      "Bash(unzip -d usr/*:*)",
      "Bash(git show *:*)",
      "Bash(git worktree *)",
      "Bash(git -C * log *)",
      "Bash(git -C * status *)",
      "Bash(git -C * diff *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git symbolic-ref *)",
      "Bash(sqlite3 */.agency/*/iscp.db *)",
      "Bash(ls */.agency/*)",
      "Bash(bats tests/*)",
      "Read(.claude/**)",
      "Read(claude/**)",
      "Read(usr/**)"
    ]
  }
}
