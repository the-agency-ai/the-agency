{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude/hooks/ref-injector.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./claude/tools/*:*)",
      "Glob(.claude/**)",
      "Glob(claude/**)",
      "Glob(usr/**)",
      "Read(.claude/**)",
      "Read(claude/**)",
      "Read(usr/**)"
    ]
  }
}
