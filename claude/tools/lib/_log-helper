#!/bin/bash
#
# _log-helper — Sourced helper for tool logging with UUID7 run IDs
#
# Source this in any tool:
#   source "$(dirname "${BASH_SOURCE[0]}")/_log-helper"
#
# Usage:
#   RUN_ID=$(log_start "tool-name" "$@")
#   # ... do work ...
#   log_end "$RUN_ID" "success" "$exit_code" "$duration_ms" "result summary"
#   log_detail "$RUN_ID" "stdout" "$captured_output"
#
# Writes to: .claude/logs/tool-runs.jsonl (append-only)
# Read with: ./tools/tool-log or usr/jordan/scripts/tool-log

_LOG_DIR="${CLAUDE_PROJECT_DIR:-.}/.claude/logs"
_LOG_FILE="${_LOG_DIR}/tool-runs.jsonl"

# Generate UUID7 (time-ordered, globally unique)
# 48-bit ms timestamp + version 7 + random
_uuid7() {
    local result
    result=$(python3 -c "
import time, os, struct
t = int(time.time() * 1000)
r = os.urandom(10)
b = struct.pack('>Q', t)[-6:] + bytes([0x70 | (r[0] & 0x0f)]) + r[1:2] + bytes([0x80 | (r[2] & 0x3f)]) + r[3:10]
h = b.hex()
print(f'{h[:8]}-{h[8:12]}-{h[12:16]}-{h[16:20]}-{h[20:32]}')
" 2>/dev/null) || true
    if [[ -z "$result" ]]; then
        echo "_log-helper: python3 unavailable, logging disabled" >&2
    fi
    echo "$result"
}

# Short form of run ID for display (first 8 chars)
_run_short() {
    echo "${1%%-*}"
}

# log_start <tool-name> [args...]
# Returns: run ID (capture with $())
log_start() {
    local tool_name="$1"
    shift
    local args="$*"
    local run_id
    run_id=$(_uuid7)

    if [[ -z "$run_id" ]]; then
        echo ""
        return
    fi

    mkdir -p "$_LOG_DIR"

    local ts
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    local agency_name
    agency_name=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || echo "unknown")
    local agent_name="${CLAUDE_SESSION_NAME:-${AGENTNAME:-unknown}}"
    local principal_name="${AGENCY_PRINCIPAL:-${USER:-unknown}}"

    jq -n -c \
        --arg run "$run_id" \
        --arg tool "$tool_name" \
        --arg ts "$ts" \
        --arg agency "$agency_name" \
        --arg principal "$principal_name" \
        --arg agent "$agent_name" \
        --arg session "${CLAUDE_SESSION_ID:-}" \
        --arg branch "$(git branch --show-current 2>/dev/null || echo '')" \
        --arg args "$(printf '%s' "$args" | head -c 200)" \
        '{run: $run, tool: $tool, event: "start", ts: $ts, agency: $agency, principal: $principal, agent: $agent, session: $session, branch: $branch, args: $args}' \
        >> "$_LOG_FILE" 2>/dev/null

    echo "$run_id"
}

# log_end <run-id> <outcome> <exit-code> <duration-ms> <summary>
log_end() {
    local run_id="$1"
    local outcome="$2"
    local exit_code="${3:-0}"
    local duration_ms="${4:-0}"
    local summary="${5:-}"

    local ts
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    jq -n -c \
        --arg run "$run_id" \
        --arg ts "$ts" \
        --arg outcome "$outcome" \
        --argjson exit "${exit_code}" \
        --argjson duration_ms "${duration_ms}" \
        --arg summary "$(echo "$summary" | head -c 500)" \
        '{run: $run, event: "end", ts: $ts, outcome: $outcome, exit: $exit, duration_ms: $duration_ms, summary: $summary}' \
        >> "$_LOG_FILE" 2>/dev/null
}

# log_detail <run-id> <channel> <content>
# For capturing verbose output (stdout, stderr, etc.)
log_detail() {
    local run_id="$1"
    local channel="$2"
    local content="$3"

    local ts
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    jq -n -c \
        --arg run "$run_id" \
        --arg ts "$ts" \
        --arg channel "$channel" \
        --arg content "$(echo "$content" | head -c 5000)" \
        '{run: $run, event: "detail", ts: $ts, channel: $channel, content: $content}' \
        >> "$_LOG_FILE" 2>/dev/null
}

# tool_output <tool-name> <run-id> <result> <icon>
# Prints the standard 3-line token-conserving output
tool_output() {
    local tool_name="$1"
    local run_id="$2"
    local result="${3:-}"
    local icon="${4:-✓}"

    echo "$tool_name [run: $(_run_short "$run_id")]"
    if [[ -n "$result" ]]; then
        echo "$result"
    fi
    echo "$icon"
}
