# _agency-update — Sync framework to latest from source
#
# Sourced by: agency update
# Arguments via: AGENCY_ARGS array
# Inherits: set -euo pipefail, AGENCY_DIR, _log-helper, colors
#
# Source detection (in order):
#   1. $AGENCY_SOURCE environment variable
#   2. ../the-agency/ (sibling directory)
#
# Protected paths from registry.json top-level array are never overwritten.
# Settings merged via settings-merge tool (array union, not overwrite).

RUN_ID=$(log_start "agency-update" "${AGENCY_ARGS[@]+"${AGENCY_ARGS[@]}"}" 2>/dev/null) || true

# --- Defaults ---
VERBOSE=false
DRY_RUN=false
TARGET_DIR=""
FROM_GITHUB=""           # D41-R10 (monofolk hotfix): github ref to fetch from
GITHUB_REPO_URL="https://github.com/the-agency-ai/the-agency.git"

_update_help() {
    cat << 'EOF'
agency update — Sync framework to latest

Usage:
  agency update [target-dir]         Update target (default: cwd)
  agency update --dry-run            Show what would change, don't apply
  agency update --from-github [ref]  Pull source from github (no local clone needed)

Options:
  --verbose             Show detailed output
  --dry-run             Preview changes without applying
  --from-github [ref]   Shallow-clone the-agency from GitHub and use as source.
                        Optional ref: tag, branch, or commit (default: latest tag).
                        Examples:  --from-github
                                   --from-github main
                                   --from-github v41.5
  --help, -h            Show this help

Source detection (in order, first match wins):
  1. --from-github flag           (D41-R10: shallow-clone from GitHub)
  2. $AGENCY_SOURCE env variable
  3. ../the-agency/ (sibling directory)

Protected paths (from registry.json) are never overwritten.
Settings merged via array union (new permissions added, existing kept).
EOF
}

# --- Parse AGENCY_ARGS ---
set -- "${AGENCY_ARGS[@]+"${AGENCY_ARGS[@]}"}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) _update_help; exit 0 ;;
        --verbose) VERBOSE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --from-github)
            # Optional ref follows the flag. If next arg is missing or starts
            # with `-` or matches a target-dir-like pattern, default to "latest".
            FROM_GITHUB="latest"
            shift
            if [[ $# -gt 0 && "$1" != -* && ! -d "$1" ]]; then
                FROM_GITHUB="$1"
                shift
            fi
            ;;
        --from-github=*) FROM_GITHUB="${1#--from-github=}"; shift ;;
        -*) echo "Unknown option: $1" >&2; _update_help; exit 1 ;;
        *) TARGET_DIR="$1"; shift ;;
    esac
done

log_info() { [[ "$VERBOSE" == "true" ]] && echo -e "${GREEN}[INFO]${NC} $1" || true; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }

_update_main() {
    trap 'log_end "$RUN_ID" "failure" $? 0 "Unexpected exit" 2>/dev/null || true' EXIT

    echo "agency update [run: ${RUN_ID:-none}]"

    # --- Resolve target ---
    TARGET_DIR="${TARGET_DIR:-$(pwd)}"
    TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" || {
        log_error "Target directory does not exist: $TARGET_DIR"
        exit 1
    }

    # --- Precondition: initialized ---
    if [[ ! -f "$TARGET_DIR/claude/config/agency.yaml" ]]; then
        log_error "Agency not initialized in $TARGET_DIR"
        echo "Run 'agency init' first."
        exit 1
    fi

    # --- Source detection ---
    # D41-R10 (monofolk hotfix): --from-github takes precedence so adopters
    # without a local the-agency clone can update directly from origin.
    local SOURCE_DIR=""
    local TMP_SOURCE_DIR=""   # Set if we shallow-cloned; teardown trap unsets
    if [[ -n "$FROM_GITHUB" ]]; then
        log_step "Fetching the-agency from GitHub (ref: $FROM_GITHUB)..."
        TMP_SOURCE_DIR=$(mktemp -d -t agency-source-XXXXXX)
        # Resolve "latest" → most-recent release tag via gh, fall back to main
        local clone_ref="$FROM_GITHUB"
        if [[ "$FROM_GITHUB" == "latest" ]]; then
            if command -v gh >/dev/null 2>&1; then
                clone_ref=$(gh release view --repo the-agency-ai/the-agency --json tagName -q .tagName 2>/dev/null) || clone_ref=""
            fi
            if [[ -z "$clone_ref" ]]; then
                log_warn "Could not resolve latest release; falling back to main"
                clone_ref="main"
            else
                log_info "Resolved latest → $clone_ref"
            fi
        fi
        if ! git clone --depth 1 --branch "$clone_ref" "$GITHUB_REPO_URL" "$TMP_SOURCE_DIR" >/dev/null 2>&1; then
            # Branch-with-tag-name might fail if it's a commit SHA — try fetch+checkout fallback.
            rm -rf "$TMP_SOURCE_DIR"
            TMP_SOURCE_DIR=$(mktemp -d -t agency-source-XXXXXX)
            if ! git clone --depth 50 "$GITHUB_REPO_URL" "$TMP_SOURCE_DIR" >/dev/null 2>&1; then
                log_error "git clone failed for $GITHUB_REPO_URL"
                rm -rf "$TMP_SOURCE_DIR"
                exit 1
            fi
            if ! git -C "$TMP_SOURCE_DIR" checkout "$clone_ref" >/dev/null 2>&1; then
                log_error "Could not checkout ref '$clone_ref' in fetched repo"
                rm -rf "$TMP_SOURCE_DIR"
                exit 1
            fi
        fi
        SOURCE_DIR="$TMP_SOURCE_DIR"
        # Update teardown trap to clean up temp clone on any exit path
        trap 'rm -rf "$TMP_SOURCE_DIR" 2>/dev/null; log_end "$RUN_ID" "failure" $? 0 "Unexpected exit" 2>/dev/null || true' EXIT
        log_info "Source: $SOURCE_DIR (shallow clone, will be removed)"
    elif [[ -n "${AGENCY_SOURCE:-}" ]]; then
        SOURCE_DIR="$AGENCY_SOURCE"
    elif [[ -f "$TARGET_DIR/../the-agency/claude/config/agency.yaml" ]]; then
        SOURCE_DIR="$(cd "$TARGET_DIR/../the-agency" && pwd)"
    elif [[ -f "$AGENCY_DIR/../claude/config/agency.yaml" ]]; then
        # Running from the framework itself — AGENCY_DIR points to claude/
        SOURCE_DIR="$(cd "$AGENCY_DIR/.." && pwd)"
    fi

    if [[ -z "$SOURCE_DIR" ]] || [[ ! -f "$SOURCE_DIR/claude/config/agency.yaml" ]]; then
        log_error "Agency source not found."
        echo ""
        echo "Three ways to provide source:"
        echo "  1. Pull from GitHub (no local clone needed):"
        echo "       agency update --from-github            # latest release tag"
        echo "       agency update --from-github main       # main branch"
        echo "       agency update --from-github v41.5      # specific tag"
        echo ""
        echo "  2. Set AGENCY_SOURCE to a local the-agency clone:"
        echo "       export AGENCY_SOURCE=~/code/the-agency"
        echo "       agency update"
        echo ""
        echo "  3. Place the-agency repo as a sibling directory:"
        echo "       ~/code/the-agency/    (source)"
        echo "       ~/code/your-project/  (target)"
        [[ -n "$TMP_SOURCE_DIR" ]] && rm -rf "$TMP_SOURCE_DIR"
        exit 1
    fi

    # --- Resolve versions ---
    local from_commit to_commit from_version to_version
    from_commit=$(grep '^  source_commit:' "$TARGET_DIR/claude/config/agency.yaml" 2>/dev/null | head -1 | sed 's/.*: *"\{0,1\}//' | sed 's/"\{0,1\} *$//' || echo "unknown")
    from_version=$(grep '^  version:' "$TARGET_DIR/claude/config/agency.yaml" 2>/dev/null | head -1 | sed 's/.*: *"\{0,1\}//' | sed 's/"\{0,1\} *$//' || echo "unknown")
    to_commit=$(git -C "$SOURCE_DIR" rev-parse HEAD 2>/dev/null || echo "unknown")
    to_version=$(grep '^  version:' "$SOURCE_DIR/claude/config/agency.yaml" 2>/dev/null | head -1 | sed 's/.*: *"\{0,1\}//' | sed 's/"\{0,1\} *$//' || echo "2.0.0")
    to_version="${to_version:-2.0.0}"

    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  Agency Update${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  Target:  $TARGET_DIR"
    echo "  Source:  $SOURCE_DIR"
    echo "  From:    ${from_version} (${from_commit:0:8})"
    echo "  To:      ${to_version} (${to_commit:0:8})"
    if [[ "$DRY_RUN" == "true" ]]; then
        echo -e "  Mode:    ${YELLOW}dry-run${NC}"
    fi
    echo ""

    # --- Load protected paths from registry ---
    local protected_paths=()
    if [[ -f "$TARGET_DIR/registry.json" ]] && command -v jq >/dev/null 2>&1; then
        while IFS= read -r path; do
            protected_paths+=("$path")
        done < <(jq -r '.protected_paths[]? // empty' "$TARGET_DIR/registry.json" 2>/dev/null)
    fi
    log_info "Protected paths: ${protected_paths[*]:-none}"

    # --- Build rsync exclude list ---
    local rsync_excludes=()
    # Always protect project-specific config
    rsync_excludes+=("--exclude" "config/agency.yaml")
    # Protected paths from registry
    for pp in "${protected_paths[@]+"${protected_paths[@]}"}"; do
        rsync_excludes+=("--exclude" "$pp")
    done

    # --- Counters ---
    local added=0 updated=0 removed=0

    # =====================================================================
    # Step 1: Sync claude/ framework directory
    # =====================================================================
    log_step "Syncing framework files"

    # Use rsync in dry-run or real mode
    # CRITICAL: NO --delete flag. Sync is ADDITIVE — add new files, update
    # existing files, but NEVER delete files that only exist in the target.
    # Project-specific tools (secret-local, provider tools, etc.) live in
    # claude/tools/ alongside framework tools. --delete would destroy them.
    # If a framework tool is renamed or removed, document it in release notes
    # for manual cleanup — that's safer than destructive sync.
    local rsync_flags=("-rlpt")
    [[ "$VERBOSE" == "true" ]] && rsync_flags+=("-v")
    [[ "$DRY_RUN" == "true" ]] && rsync_flags+=("--dry-run")

    # Sync claude/ (excluding agency.yaml, protected paths, and workstreams)
    local rsync_output
    rsync_output=$(rsync "${rsync_flags[@]}" \
        "${rsync_excludes[@]+"${rsync_excludes[@]}"}" \
        --exclude "workstreams/" \
        --exclude "usr/" \
        --itemize-changes \
        "$SOURCE_DIR/claude/" "$TARGET_DIR/claude/" 2>&1) || true

    # Count changes from itemize output
    if [[ -n "$rsync_output" ]]; then
        added=$(echo "$rsync_output" | grep -c '^>f+++' || true)
        updated=$(echo "$rsync_output" | grep -c '^>f\.\.' || true)
        removed=$(echo "$rsync_output" | grep -c '^\*deleting' || true)
        [[ "$VERBOSE" == "true" ]] && echo "$rsync_output"
    fi

    log_info "claude/ sync: +$added ~$updated -$removed"

    # =====================================================================
    # Step 2: Sync .claude/ discovery files
    # =====================================================================
    log_step "Syncing .claude/ discovery files"

    # Skills
    if [[ -d "$SOURCE_DIR/.claude/skills" ]]; then
        mkdir -p "$TARGET_DIR/.claude/skills"
        local skill_output
        skill_output=$(rsync "${rsync_flags[@]}" \
            --itemize-changes \
            "$SOURCE_DIR/.claude/skills/" "$TARGET_DIR/.claude/skills/" 2>&1) || true
        if [[ -n "$skill_output" ]] && [[ "$VERBOSE" == "true" ]]; then
            echo "$skill_output"
        fi
        local skill_added
        skill_added=$(echo "${skill_output:-}" | grep -c '^>f+++' || true)
        added=$((added + skill_added))
    fi

    # Commands
    if [[ -d "$SOURCE_DIR/.claude/commands" ]]; then
        mkdir -p "$TARGET_DIR/.claude/commands"
        local cmd_output
        cmd_output=$(rsync "${rsync_flags[@]}" \
            --itemize-changes \
            "$SOURCE_DIR/.claude/commands/" "$TARGET_DIR/.claude/commands/" 2>&1) || true
        if [[ -n "$cmd_output" ]] && [[ "$VERBOSE" == "true" ]]; then
            echo "$cmd_output"
        fi
    fi

    # =====================================================================
    # Step 3: Settings merge
    # =====================================================================
    log_step "Merging settings"

    if [[ -f "$TARGET_DIR/claude/tools/settings-merge" ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            bash "$TARGET_DIR/claude/tools/settings-merge" --dry-run 2>/dev/null || true
        else
            bash "$TARGET_DIR/claude/tools/settings-merge" 2>/dev/null || log_warn "settings-merge failed — settings.json unchanged"
        fi
    else
        log_warn "settings-merge tool not found — skipping settings merge"
    fi

    # =====================================================================
    # Step 4: Update agency.yaml framework section + append new top-level
    # sections (issue #56 — new sections from source never propagated)
    # =====================================================================
    log_step "Updating agency.yaml"

    if [[ "$DRY_RUN" == "false" ]]; then
        local yaml_file="$TARGET_DIR/claude/config/agency.yaml"
        local src_yaml="$SOURCE_DIR/claude/config/agency.yaml"
        local updated_at
        updated_at=$(date -u '+%Y-%m-%dT%H:%M:%S+00:00')

        # --- Update metadata in the framework section (existing behavior) ---
        if [[ "$(uname)" == "Darwin" ]]; then
            sed -i '' "s|^  version: .*|  version: \"$to_version\"|" "$yaml_file"
            sed -i '' "s|^  updated_at: .*|  updated_at: \"$updated_at\"|" "$yaml_file"
            sed -i '' "s|^  source_commit: .*|  source_commit: \"$to_commit\"|" "$yaml_file"
        else
            sed -i "s|^  version: .*|  version: \"$to_version\"|" "$yaml_file"
            sed -i "s|^  updated_at: .*|  updated_at: \"$updated_at\"|" "$yaml_file"
            sed -i "s|^  source_commit: .*|  source_commit: \"$to_commit\"|" "$yaml_file"
        fi

        # --- Append new top-level sections from source (issue #56) ---
        # Top-level key: a line matching ^[A-Za-z_][A-Za-z0-9_]*:
        # For each key present in source but missing in target, extract the
        # section (from that key through the line before the next top-level
        # key or EOF) and append it to target with a comment marker.
        local added_sections=""
        local src_keys tgt_keys
        # Dedupe in-place to tolerate duplicate top-level keys in source
        src_keys=$(awk '/^[A-Za-z_][A-Za-z0-9_]*:/ { sub(/:.*/,""); if (!seen[$0]++) print }' "$src_yaml" 2>/dev/null || true)
        tgt_keys=$(awk '/^[A-Za-z_][A-Za-z0-9_]*:/ { sub(/:.*/,""); if (!seen[$0]++) print }' "$yaml_file" 2>/dev/null || true)

        local key
        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            # Skip if key already present in target
            if printf '%s\n' "$tgt_keys" | grep -qxF "$key"; then
                continue
            fi

            # Extract section for this key from source: from ^key: up to (but
            # not including) the next top-level key, trimming trailing blank
            # lines from the block.
            local section
            section=$(awk -v k="$key" '
                $0 ~ "^"k":" { in_block=1; print; next }
                in_block && /^[A-Za-z_][A-Za-z0-9_]*:/ { in_block=0 }
                in_block { print }
            ' "$src_yaml")

            [[ -z "$section" ]] && continue

            # Buffer — we will append all new sections in one block
            if [[ -z "$added_sections" ]]; then
                added_sections=$(printf '\n# ─────────────────────────────────────────────────────────────────────────\n# New sections added by agency update — review and customize as needed.\n# Added by framework version %s (%s)\n# ─────────────────────────────────────────────────────────────────────────\n' "$to_version" "$to_commit")
            fi
            added_sections=$(printf '%s\n\n%s' "$added_sections" "$section")
            log_info "  + new section: $key"
        done <<<"$src_keys"

        if [[ -n "$added_sections" ]]; then
            # Ensure target ends with newline before appending
            [[ -n "$(tail -c1 "$yaml_file" 2>/dev/null)" ]] && printf '\n' >> "$yaml_file"
            printf '%s\n' "$added_sections" >> "$yaml_file"
            log_info "Appended new top-level sections to agency.yaml"
        fi
    fi

    log_info "Updated framework section in agency.yaml"

    # =====================================================================
    # Step 5: Update manifest
    # =====================================================================
    log_step "Updating manifest"

    if [[ "$DRY_RUN" == "false" ]] && [[ -f "$TARGET_DIR/claude/config/manifest.json" ]] && command -v jq >/dev/null 2>&1; then
        local tmp_manifest
        tmp_manifest=$(mktemp)
        jq --arg ver "$to_version" --arg ts "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
            '.project.framework_version = $ver | .project.updated_at = $ts' \
            "$TARGET_DIR/claude/config/manifest.json" > "$tmp_manifest" 2>/dev/null && \
            mv "$tmp_manifest" "$TARGET_DIR/claude/config/manifest.json"
    fi

    log_info "Manifest updated"

    # =====================================================================
    # Step 6: Write update handoff
    # =====================================================================
    log_step "Writing update handoff"

    if [[ "$DRY_RUN" == "false" ]]; then
        # Read previous handoff summary before archiving
        local prev_summary=""
        local handoff_path
        handoff_path=$(bash "$TARGET_DIR/claude/tools/handoff" path 2>/dev/null || echo "")
        if [[ -n "$handoff_path" ]] && [[ -f "$handoff_path" ]]; then
            # Get first 20 lines of content (after frontmatter) for summary
            prev_summary=$(sed '1,/^---$/d; 1,/^---$/d' "$handoff_path" 2>/dev/null | head -20 || true)
        fi

        # Archive existing handoff
        bash "$TARGET_DIR/claude/tools/handoff" archive 2>/dev/null || true

        # Write update handoff directly (handoff write signals the agent,
        # but we want to write the content ourselves)
        if [[ -n "$handoff_path" ]]; then
            cat > "$handoff_path" << UPDATE_EOF
---
type: agency-update
date: $(date '+%Y-%m-%d %H:%M')
from_commit: ${from_commit:0:8}
to_commit: ${to_commit:0:8}
---

## Agency Update

Updated framework from ${from_version} (${from_commit:0:8}) to ${to_version} (${to_commit:0:8}).

### Changes
- $added files added, $updated files updated, $removed files removed
- Settings merged via array union
- Framework section in agency.yaml updated

### Verify the update
Run \`agency verify\` to confirm everything is in order.

### Previous session state
${prev_summary:-No previous session state.}
UPDATE_EOF
        fi
    fi

    log_info "Update handoff written"

    # =====================================================================
    # Done
    # =====================================================================
    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [[ "$DRY_RUN" == "true" ]]; then
        echo -e "${YELLOW}  Agency Update — Dry Run Complete${NC}"
    else
        echo -e "${GREEN}  Agency Updated!${NC}"
    fi
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  From:    ${from_version} (${from_commit:0:8})"
    echo "  To:      ${to_version} (${to_commit:0:8})"
    echo "  Changes: +$added ~$updated -$removed"
    echo ""
    if [[ "$DRY_RUN" == "false" ]]; then
        echo "Next steps:"
        echo "  1. Run 'agency verify' to confirm"
        echo "  2. Review changes with 'git diff'"
        echo "  3. Commit when satisfied"
    fi
    echo ""

    trap - EXIT
    # D41-R10: clean up shallow-clone temp dir on success path
    [[ -n "$TMP_SOURCE_DIR" ]] && rm -rf "$TMP_SOURCE_DIR" 2>/dev/null
    log_end "$RUN_ID" "success" 0 0 "Updated from ${from_commit:0:8} to ${to_commit:0:8}" 2>/dev/null || true
}

_update_main
