#!/bin/bash
# GitHub Release operations wrapper
#
# Usage:
#   ./claude/tools/gh-release list
#   ./claude/tools/gh-release create v1.0.0 --notes "Release notes"
#   ./claude/tools/gh-release view v1.0.0
#
# This is a convenience wrapper around ./claude/tools/gh release
# All operations are logged via the base gh wrapper.
#
# Note: For full release workflow (tagging, changelog, etc.),
# use ./claude/tools/release instead. This is for direct gh release operations.
#
# Related: REQUEST-jordan-0072

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Tool version
TOOL_VERSION="1.0.0-20260120-000001"

# Version check
if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
    echo "gh-release $TOOL_VERSION"
    exit 0
fi

# Help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] || [[ $# -eq 0 ]]; then
    cat << 'EOF'
gh-release - GitHub Release operations

Usage:
  ./claude/tools/gh-release <command> [arguments...]

Commands:
  list                    List releases
  create <tag>            Create a release
  view <tag>              View a release
  delete <tag>            Delete a release
  download <tag>          Download release assets
  upload <tag> <files>    Upload assets to a release

Examples:
  ./claude/tools/gh-release list --limit 5
  ./claude/tools/gh-release create v1.0.0 --title "Version 1.0" --notes "First release"
  ./claude/tools/gh-release view v1.0.0
  ./claude/tools/gh-release delete v1.0.0-beta --yes

Note: For full release workflow with changelog and tagging,
use ./claude/tools/release instead.

All operations use ./claude/tools/gh for token injection and logging.
EOF
    exit 0
fi

# Pass through to gh release
exec "$SCRIPT_DIR/gh" release "$@"
