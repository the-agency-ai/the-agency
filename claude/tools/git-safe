#!/bin/bash
# What Problem: Agents run raw git commands that can be destructive or violate
# conventions (git add -A, git add ., rebasing, force push). There is no safe
# subset of git operations that agents can use without risk of breaking the
# working tree or violating The Agency's merge-not-rebase discipline.
#
# How & Why: A curated set of read-only and carefully-guarded write operations
# exposed as subcommands. Read operations (status, log, diff, branch, show,
# blame) pass through directly. The only write operation — git add — blocks
# wildcard/directory patterns that could stage secrets or binaries. The
# merge-from-master subcommand enforces clean-tree merges with auto-detection
# of main vs master. Hookify rules can trust git-safe invocations because the
# dangerous patterns are blocked at this layer.
#
# Written: 2026-04-14 during devex workstream (git-safe family)

set -euo pipefail

TOOL_VERSION="1.0.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi

# Colors
if [[ -f "$SCRIPT_DIR/lib/_colors" ]]; then
    source "$SCRIPT_DIR/lib/_colors"
else
    RED=$'\033[0;31m' GREEN=$'\033[0;32m' YELLOW=$'\033[1;33m' BLUE=$'\033[0;34m' NC=$'\033[0m'
fi

die() { echo "${RED}[ERROR]${NC} $1" >&2; exit 1; }

usage() {
    cat <<'USAGE'
git-safe — Safe git operations for all agents

Usage: ./claude/tools/git-safe <subcommand> [args...]

Subcommands (read-only):
  status [args]          git status
  log [args]             git log
  diff [args]            git diff
  branch                 Show current branch name
  show [args]            git show
  blame [args]           git blame

Subcommands (guarded write):
  add <file> [file...]         Stage explicit file paths (blocks -A, --all, ., wildcards)
  rm <file> [file...]          Remove files (also removes from index) — blocks wildcards/dirs
  merge-from-master            Merge main/master into current branch (clean tree required)
                               Pass --remote to merge origin/main instead of local main
  resolve-conflict <file> --ours|--theirs
                               Resolve a conflicted file by taking one side, then stage it.
                               Only valid mid-merge (MERGE_HEAD present).
  merge-abort                  Abort an in-progress merge (wraps git merge --abort).

Options:
  --help                 Show this help
  --version              Show version
USAGE
    exit 0
}

# --- Subcommand: status ---
cmd_status() {
    git status "$@"
}

# --- Subcommand: log ---
cmd_log() {
    git log "$@"
}

# --- Subcommand: diff ---
cmd_diff() {
    git diff "$@"
}

# --- Subcommand: branch ---
cmd_branch() {
    git branch --show-current
}

# --- Subcommand: show ---
cmd_show() {
    git show "$@"
}

# --- Subcommand: blame ---
cmd_blame() {
    git blame "$@"
}

# --- Subcommand: add ---
cmd_add() {
    [[ $# -eq 0 ]] && die "git-safe add requires explicit file paths. Usage: git-safe add <file> [file...]"

    for arg in "$@"; do
        # Block flags that stage everything
        case "$arg" in
            -A|--all)
                die "git-safe add blocks '$arg' — specify explicit file paths instead."
                ;;
        esac

        # Block bare directory paths and wildcards
        if [[ "$arg" == "." || "$arg" == "./" || "$arg" == ".." || "$arg" == "../" ]]; then
            die "git-safe add blocks '$arg' — specify explicit file paths instead."
        fi

        # Block glob wildcards (unquoted * would be expanded by shell, but quoted * arrives here)
        if [[ "$arg" == "*" || "$arg" == "**" ]]; then
            die "git-safe add blocks '$arg' — specify explicit file paths instead."
        fi

        # Block bare directory paths
        if [[ -d "$arg" ]]; then
            die "git-safe add blocks directory '$arg' — specify individual files within the directory."
        fi
    done

    git add "$@"
    echo "${GREEN}Staged:${NC} $*"
}

# --- Subcommand: rm ---
# Delete files from working tree AND index. Guards match cmd_add: no wildcards,
# no bare directories, no -r/-rf flags (those could nuke whole trees).
cmd_rm() {
    [[ $# -eq 0 ]] && die "git-safe rm requires explicit file paths. Usage: git-safe rm <file> [file...]"

    for arg in "$@"; do
        case "$arg" in
            -r|-R|-rf|-rR|--recursive|-f|--force)
                die "git-safe rm blocks '$arg' — remove individual files explicitly."
                ;;
        esac
        if [[ "$arg" == "." || "$arg" == "./" || "$arg" == ".." || "$arg" == "../" ]]; then
            die "git-safe rm blocks '$arg' — specify explicit file paths instead."
        fi
        if [[ "$arg" == "*" || "$arg" == "**" ]]; then
            die "git-safe rm blocks '$arg' — specify explicit file paths instead."
        fi
        if [[ -d "$arg" ]]; then
            die "git-safe rm blocks directory '$arg' — remove individual files within the directory."
        fi
    done

    # QG fix (D41-R4+R6+R7): `--` terminator — filenames starting with '-' that
    # weren't caught by the arg-scan deny-list should never be interpreted as
    # flags by git rm. Defense-in-depth.
    git rm -- "$@"
    echo "${GREEN}Removed:${NC} $*"
}

# --- Subcommand: resolve-conflict ---
# Mid-merge helper: take one side of a conflicted file and stage it.
# Only valid when MERGE_HEAD exists — otherwise there's no merge to resolve.
cmd_resolve_conflict() {
    local file=""
    local side=""
    for arg in "$@"; do
        case "$arg" in
            --ours)   side="ours" ;;
            --theirs) side="theirs" ;;
            -*)       die "Unknown flag for resolve-conflict: $arg (use --ours or --theirs)" ;;
            *)
                if [[ -n "$file" ]]; then
                    die "resolve-conflict takes exactly one file."
                fi
                file="$arg"
                ;;
        esac
    done

    [[ -z "$file" ]] && die "resolve-conflict requires a file path. Usage: git-safe resolve-conflict <file> --ours|--theirs"
    [[ -z "$side" ]] && die "resolve-conflict requires --ours or --theirs."

    local git_dir
    git_dir=$(git rev-parse --git-dir 2>/dev/null) || die "Not a git repository."
    if [[ ! -f "$git_dir/MERGE_HEAD" ]]; then
        die "No merge in progress (no MERGE_HEAD). resolve-conflict is only valid mid-merge."
    fi

    # Verify file is actually conflicted (has unmerged entry in index)
    if ! git ls-files -u -- "$file" 2>/dev/null | grep -q .; then
        die "File '$file' is not conflicted (no unmerged index entry)."
    fi

    git checkout "--$side" -- "$file"
    git add -- "$file"
    echo "${GREEN}Resolved:${NC} $file (took $side)"
}

# --- Subcommand: merge-abort ---
cmd_merge_abort() {
    local git_dir
    git_dir=$(git rev-parse --git-dir 2>/dev/null) || die "Not a git repository."
    if [[ ! -f "$git_dir/MERGE_HEAD" ]]; then
        die "No merge in progress (no MERGE_HEAD). Nothing to abort."
    fi
    git merge --abort
    echo "${GREEN}Merge aborted.${NC} Working tree restored to pre-merge state."
}

# --- Subcommand: merge-from-master ---
cmd_merge_from_master() {
    # Auto-detect main branch name
    local main_branch=""
    if git show-ref --verify refs/heads/main &>/dev/null; then
        main_branch="main"
    elif git show-ref --verify refs/heads/master &>/dev/null; then
        main_branch="master"
    else
        die "Cannot find main or master branch."
    fi

    local current_branch
    current_branch=$(git branch --show-current)

    if [[ "$current_branch" == "$main_branch" ]]; then
        die "Already on $main_branch — merge-from-master is for feature branches."
    fi

    # Refuse if working tree is dirty
    if ! git diff --quiet || ! git diff --cached --quiet; then
        die "Working tree is dirty. Commit or stash changes first (see /worktree-sync)."
    fi

    # Check for untracked files that might cause merge conflicts
    # (informational only — untracked files don't block merge)

    # Optional --remote flag: merge origin/$main_branch instead of local main.
    # Useful when local main is behind origin/main and cannot be advanced
    # (e.g., captain sitting on a feature branch post-PR-merge).
    local target="$main_branch"
    local label="$main_branch"
    for arg in "$@"; do
        if [[ "$arg" == "--remote" ]]; then
            if ! git show-ref --verify "refs/remotes/origin/$main_branch" &>/dev/null; then
                die "origin/$main_branch does not exist. Fetch first."
            fi
            target="origin/$main_branch"
            label="origin/$main_branch"
        fi
    done

    echo "${BLUE}Merging $label into $current_branch...${NC}"
    if git merge "$target" --no-edit; then
        echo "${GREEN}Merge complete.${NC} $label merged into $current_branch."
    else
        die "Merge failed — resolve conflicts manually, then commit."
    fi
}

# --- Main dispatch ---
[[ $# -eq 0 ]] && usage

case "$1" in
    --help|-h)    usage ;;
    --version)    echo "git-safe $TOOL_VERSION"; exit 0 ;;
    status)       shift; cmd_status "$@" ;;
    log)          shift; cmd_log "$@" ;;
    diff)         shift; cmd_diff "$@" ;;
    branch)       shift; cmd_branch "$@" ;;
    show)         shift; cmd_show "$@" ;;
    blame)        shift; cmd_blame "$@" ;;
    add)              shift; cmd_add "$@" ;;
    rm)               shift; cmd_rm "$@" ;;
    resolve-conflict) shift; cmd_resolve_conflict "$@" ;;
    merge-abort)      shift; cmd_merge_abort "$@" ;;
    merge-from-master) shift; cmd_merge_from_master "$@" ;;
    *)            die "Unknown subcommand: $1 — run 'git-safe --help' for usage." ;;
esac
