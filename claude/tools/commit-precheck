#!/bin/bash
# What Problem: The original commit-precheck ran 5 Node.js-centric steps (format,
# lint, typecheck, test, code-review) on every commit. Bash tools didn't trigger
# tests at all (not matched by has_app_code). App code triggered ALL 703 BATS tests.
# Code review spawned multi-agent sessions at pre-commit — way too heavy.
#
# How & Why: Rewrite around three principles: (1) classify staged files to decide
# what checks to run, (2) use test-scoper for surgical test targeting instead of
# running everything, (3) 60s budget with graceful timeout (warn, don't block).
# Stripped code-review entirely — it belongs in /iteration-complete and
# /phase-complete, not pre-commit. Kept format/lint/typecheck for JS/TS projects
# that have them. Added stage-hash warn for QGR receipt tracking.
#
# Written: 2026-04-07 during devex Phase 1.3 (commit-precheck rewrite)
#
# Usage: ./claude/tools/commit-precheck [options]
#   --verbose    Show detailed output
#   --dry-run    Show what would run without executing
#   --version    Show version
#   --help       Show this help
#
# Exit codes:
#   0 = all checks passed (or no checks needed)
#   2 = blocking check failed

set -euo pipefail

TOOL_VERSION="3.0.0"

SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi
RUN_ID=$(log_start "commit-precheck" "$@" 2>/dev/null) || true

VERBOSE=false
DRY_RUN=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --verbose|-v) VERBOSE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --version) echo "commit-precheck $TOOL_VERSION"; exit 0 ;;
        --help|-h)
            sed -n '/^# Usage:/,/^# Exit/p' "$0" | sed 's/^# //' | sed 's/^#//'
            exit 0 ;;
        *) shift ;;
    esac
done

# ─────────────────────────────────────────────────────────────────────────────
# Merge commit skip — PR branch merge commits are packaging, not authored code.
# The worktree agent's QG already validated the content. If the code has lint
# issues, that's a QG gap in the worktree — not something to catch here.
# ─────────────────────────────────────────────────────────────────────────────

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) || true
if [[ -f "${GIT_DIR}/MERGE_HEAD" ]]; then
    log_end "$RUN_ID" "skip" "0" "0" "merge commit — skipping pre-commit checks" 2>/dev/null || true
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

log_msg() {
    local level="$1" message="$2"
    if [[ "$VERBOSE" == "true" ]]; then
        echo "[$level] $message"
    elif [[ -n "${RUN_ID:-}" ]]; then
        curl -s -X POST "http://127.0.0.1:3141/api/log" \
            -H "Content-Type: application/json" \
            -d "{\"service\":\"commit-precheck\",\"level\":\"$level\",\"message\":\"$message\",\"runId\":\"$RUN_ID\"}" \
            > /dev/null 2>&1 || true
    fi
}
log_info() { log_msg "info" "$1"; }
log_warn() { log_msg "warn" "$1"; }

end_run() {
    [[ "$VERBOSE" == "true" ]] && return
    log_end "$RUN_ID" "$1" "0" "0" "$2" 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────────────────────────
# Timeout wrapper
# ─────────────────────────────────────────────────────────────────────────────

run_with_timeout() {
    local timeout_secs="$1"; shift
    if command -v gtimeout >/dev/null 2>&1; then
        # Use --kill-after to nuke the process group if SIGTERM doesn't take.
        # Without this, bats can leave orphaned bats-exec-test processes.
        gtimeout --kill-after=5 "$timeout_secs" "$@"
    elif command -v timeout >/dev/null 2>&1; then
        timeout --kill-after=5 "$timeout_secs" "$@"
    else
        # Manual fallback with process group kill (-pid sends to whole pgroup).
        # The trap ensures the watchdog dies even if the main process exits early.
        "$@" &
        local pid=$!
        (sleep "$timeout_secs" && kill -TERM "-$pid" 2>/dev/null && sleep 5 && kill -KILL "-$pid" 2>/dev/null) &
        local watchdog=$!
        wait "$pid" 2>/dev/null
        local rc=$?
        kill -KILL "$watchdog" 2>/dev/null
        wait "$watchdog" 2>/dev/null
        # Best-effort: kill the original pid's process group too
        kill -KILL "-$pid" 2>/dev/null
        return $rc
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Stage classification
# ─────────────────────────────────────────────────────────────────────────────

classify_staged() {
    local staged_files
    staged_files=$(git diff --cached --name-only)

    # Check for markdown-only
    local non_md
    non_md=$(echo "$staged_files" | grep -vE '\.(md|txt|json|yaml|yml)$' || true)
    if [[ -z "$non_md" ]]; then
        echo "docs-only"
        return
    fi

    # Check for app code (JS/TS/Python/Rust/Go/etc.)
    if echo "$staged_files" | grep -qE '\.(ts|tsx|js|jsx|py|rs|go|java|swift|vue|svelte)$'; then
        echo "app-code"
        return
    fi

    # Check for tool/test code (bash scripts in claude/tools/ or tests/)
    if echo "$staged_files" | grep -qE '^(claude/tools/|tests/)'; then
        echo "tool-code"
        return
    fi

    # Everything else: config, yaml, scripts outside tools/, etc.
    echo "config-only"
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

main() {
    echo "commit-precheck [run: ${RUN_ID:-none}]"

    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    cd "$REPO_ROOT"

    # ────────────────────────────────────────────────────────────────────────
    # Gate 0: block Test User attribution (merge-durable guard against the
    # recurring BATS pollution bug — dispatches #109 and #171).
    #
    # If .git/config grew a [user] section with Test User / test@example.com,
    # a BATS test leaked pre-commit env vars and polluted the live config.
    # Block the commit, print diagnostics, and tell the author how to clean.
    # ────────────────────────────────────────────────────────────────────────
    local git_user_name git_user_email
    git_user_name=$(git config user.name 2>/dev/null || true)
    git_user_email=$(git config user.email 2>/dev/null || true)
    if [[ "$git_user_name" == "Test User" ]] || [[ "$git_user_email" == "test@example.com" ]]; then
        echo "✗ BLOCKED: commit identity is Test User <test@example.com>" >&2
        echo "  → Your .git/config has a polluted [user] section (likely from a" >&2
        echo "    BATS test leaking env vars). Clean with:" >&2
        echo "      git config --local --unset user.email" >&2
        echo "      git config --local --unset user.name" >&2
        echo "    Then verify: git config user.name && git config user.email" >&2
        echo "  → Root cause: see dispatches #109 and #171." >&2
        echo "*OFFENDERS WILL BE FED TO THE — CUTE — ATTACK KITTENS!*" >&2
        end_run "blocked" "Test User attribution"
        exit 1
    fi
    if grep -q '^\[user\]' "$REPO_ROOT/.git/config" 2>/dev/null; then
        if grep -A2 '^\[user\]' "$REPO_ROOT/.git/config" 2>/dev/null | grep -qE 'Test User|test@example\.com'; then
            echo "✗ BLOCKED: .git/config contains a polluted [user] section" >&2
            echo "  → Clean with: git config --local --unset-all user.email && git config --local --unset-all user.name" >&2
            echo "*OFFENDERS WILL BE FED TO THE — CUTE — ATTACK KITTENS!*" >&2
            end_run "blocked" "Polluted .git/config [user] section"
            exit 1
        fi
    fi

    # ────────────────────────────────────────────────────────────────────────
    # Gate 1: Large-file blocker (D41-Rn — monofolk REQUEST, dispatch #369/#371)
    #
    # Block commits that stage files above BLOCK_BYTES; warn above WARN_BYTES.
    # Rationale: large binaries pollute history and inflate clones forever.
    # GitHub soft-caps at 50MB warn / 100MB reject — by that point the commit
    # is already local and requires history rewrite to remove.
    #
    # Defaults: warn at 1 MB, block at 10 MB.
    # Env overrides: LARGE_FILE_WARN_BYTES, LARGE_FILE_BLOCK_BYTES.
    # Bypass: ALLOW_LARGE_COMMIT=1 (set by git-safe-commit --allow-large).
    # Exceptions: claude/config/large-file-exceptions.txt (one glob per line).
    # ────────────────────────────────────────────────────────────────────────
    check_large_files() {
        local warn_bytes="${LARGE_FILE_WARN_BYTES:-1048576}"     # 1 MB
        local block_bytes="${LARGE_FILE_BLOCK_BYTES:-10485760}"  # 10 MB
        local exceptions_file="$REPO_ROOT/claude/config/large-file-exceptions.txt"
        local exceptions=()
        if [[ -f "$exceptions_file" ]]; then
            while IFS= read -r line; do
                # Skip blanks and comments
                [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
                exceptions+=("$line")
            done < "$exceptions_file"
        fi

        local staged
        staged=$(git diff --cached --name-only --diff-filter=AM)
        [[ -z "$staged" ]] && return 0

        local blocked=()
        local warned=()
        while IFS= read -r f; do
            [[ -z "$f" || ! -f "$f" ]] && continue
            # Check exceptions — match against full path OR basename.
            # Enable globstar so `**/*.bin` works at any depth.
            shopt -s globstar 2>/dev/null || true
            local is_exempt=false
            local base="${f##*/}"
            for pat in "${exceptions[@]+"${exceptions[@]}"}"; do
                # shellcheck disable=SC2053
                if [[ "$f" == $pat || "$base" == $pat ]]; then is_exempt=true; break; fi
            done
            [[ "$is_exempt" == "true" ]] && continue

            local size
            if size=$(wc -c < "$f" 2>/dev/null); then
                size=$(echo "$size" | tr -d ' ')
            else
                continue
            fi
            if [[ "$size" -gt "$block_bytes" ]]; then
                blocked+=("$f|$size")
            elif [[ "$size" -gt "$warn_bytes" ]]; then
                warned+=("$f|$size")
            fi
        done <<< "$staged"

        # Warn (informational, doesn't block)
        if [[ ${#warned[@]} -gt 0 ]]; then
            echo "⚠ Large file warning (>$(( warn_bytes / 1048576 )) MB):" >&2
            for entry in "${warned[@]}"; do
                local path="${entry%|*}" sz="${entry#*|}"
                printf "  %s  %.2f MB\n" "$path" "$(echo "scale=2; $sz / 1048576" | bc 2>/dev/null || echo "?")" >&2
            done
        fi

        # Block (unless overridden)
        if [[ ${#blocked[@]} -gt 0 ]]; then
            if [[ "${ALLOW_LARGE_COMMIT:-}" == "1" ]]; then
                echo "⚠ ALLOW_LARGE_COMMIT=1 — proceeding with large files:" >&2
                for entry in "${blocked[@]}"; do
                    local path="${entry%|*}" sz="${entry#*|}"
                    printf "  %s  %.2f MB\n" "$path" "$(echo "scale=2; $sz / 1048576" | bc 2>/dev/null || echo "?")" >&2
                done
                return 0
            fi
            echo "✗ BLOCKED: staged file(s) exceed size threshold ($(( block_bytes / 1048576 )) MB):" >&2
            for entry in "${blocked[@]}"; do
                local path="${entry%|*}" sz="${entry#*|}"
                printf "  %s  %.2f MB\n" "$path" "$(echo "scale=2; $sz / 1048576" | bc 2>/dev/null || echo "?")" >&2
            done
            cat >&2 <<'EOF'

If this is intentional:
  1. Use Git LFS:      git lfs track '*.bin' && git add .gitattributes
  2. Override once:    ./claude/tools/git-safe-commit --allow-large ...
  3. Permanent exempt: add glob to claude/config/large-file-exceptions.txt

*OFFENDERS WILL BE FED TO THE — CUTE — ATTACK KITTENS!*
EOF
            end_run "blocked" "Large file exceeds block threshold"
            exit 2
        fi
        return 0
    }
    check_large_files

    # No staged changes = nothing to check
    if git diff --cached --quiet; then
        log_info "No staged changes"
        end_run "success" "No staged changes"
        echo "No staged changes to check"
        echo "✓"
        exit 0
    fi

    # Step 1: Classify
    local classification
    classification=$(classify_staged)
    log_info "Classification: $classification"

    # Fast path: docs/config only — no tests needed
    if [[ "$classification" == "docs-only" || "$classification" == "config-only" ]]; then
        log_info "Fast path: $classification — skipping all checks"
        end_run "success" "Fast path: $classification"
        echo "All pre-commit checks passed"
        echo "✓"
        exit 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Classification: $classification"
    fi

    # Step 2: Format + Lint + Typecheck (app-code only, if scripts exist)
    if [[ "$classification" == "app-code" ]]; then
        local PM="npm"
        [[ -f "pnpm-lock.yaml" ]] && PM="pnpm"
        [[ -f "yarn.lock" ]] && PM="yarn"

        # Format (auto-fix, non-blocking)
        if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.format ? 0 : 1)" 2>/dev/null; then
            log_info "Formatting..."
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "[dry-run] Would run: $PM run format"
            else
                run_with_timeout 30 $PM run format >/dev/null 2>&1 || log_warn "Format failed (continuing)"
            fi
        fi

        # Lint (auto-fix, non-blocking)
        if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts['lint:fix'] ? 0 : 1)" 2>/dev/null; then
            log_info "Linting..."
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "[dry-run] Would run: $PM run lint:fix"
            else
                run_with_timeout 30 $PM run lint:fix >/dev/null 2>&1 || log_warn "Lint failed (continuing)"
            fi
        fi

        # Typecheck (blocking)
        if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.typecheck ? 0 : 1)" 2>/dev/null; then
            log_info "Type checking..."
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "[dry-run] Would run: $PM run typecheck"
            else
                if ! run_with_timeout 60 $PM run typecheck >/dev/null 2>&1; then
                    end_run "failure" "Type check failed"
                    echo "Type check failed"
                    echo "✗"
                    exit 2
                fi
            fi
        fi
    fi

    # Step 3: Scoped tests (tool-code or app-code)
    local test_scoper="$SCRIPT_DIR/test-scoper"
    if [[ -x "$test_scoper" ]]; then
        local scoped_tests
        scoped_tests=$(git diff --cached --name-only | "$test_scoper" 2>/dev/null || true)

        if [[ -n "$scoped_tests" ]]; then
            local test_count
            test_count=$(echo "$scoped_tests" | wc -l | tr -d ' ')
            log_info "Scoped tests: $test_count file(s)"

            if [[ "$DRY_RUN" == "true" ]]; then
                echo "[dry-run] Would run $test_count scoped test file(s):"
                echo "$scoped_tests" | sed 's|.*/||'
            else
                # Clean git env vars leaked by pre-commit hook context.
                # Without this, BATS tests that create their own git repos
                # would operate on the outer repo's index/dir instead.
                unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE GIT_AUTHOR_DATE GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL 2>/dev/null || true

                # Run scoped BATS tests with scaled timeout
                # Base: 60s for ≤5 files, +15s per additional file (merge commits
                # can touch 35+ files and need ~200s). See dispatch #198.
                local bats_files
                bats_files=$(echo "$scoped_tests" | grep '\.bats$' || true)
                if [[ -n "$bats_files" ]]; then
                    local bats_args
                    bats_args=$(echo "$bats_files" | tr '\n' ' ')
                    local bats_count
                    bats_count=$(echo "$bats_files" | wc -l | tr -d ' ')
                    local bats_timeout=60
                    if [[ "$bats_count" -gt 5 ]]; then
                        bats_timeout=$(( 60 + (bats_count - 5) * 15 ))
                    fi
                    log_info "Running: bats $bats_args (timeout: ${bats_timeout}s for $bats_count files)"

                    local test_output
                    if test_output=$(run_with_timeout "$bats_timeout" bats $bats_args 2>&1); then
                        log_info "Scoped tests passed"
                    else
                        local exit_code=$?
                        if [[ $exit_code -eq 124 ]]; then
                            log_warn "Tests timed out at 60s (allowing commit)"
                            echo "WARNING: Tests timed out at 60s"
                        else
                            end_run "failure" "Scoped tests failed"
                            echo "Scoped tests failed"
                            # Show last 20 lines of output for diagnosis
                            echo "$test_output" | tail -20
                            echo "✗"
                            exit 2
                        fi
                    fi
                fi

                # Run scoped vitest/jest if any .test.ts/.spec.ts matched
                local js_tests
                js_tests=$(echo "$scoped_tests" | grep -E '\.(test|spec)\.(ts|js|tsx|jsx)$' || true)
                if [[ -n "$js_tests" ]]; then
                    log_info "Running JS/TS tests..."
                    if ! run_with_timeout 60 npx vitest run $js_tests >/dev/null 2>&1; then
                        local exit_code=$?
                        if [[ $exit_code -eq 124 ]]; then
                            log_warn "JS tests timed out at 60s (allowing commit)"
                        else
                            end_run "failure" "JS tests failed"
                            echo "JS tests failed"
                            echo "✗"
                            exit 2
                        fi
                    fi
                fi
            fi
        else
            log_info "No scoped tests found for staged files"
        fi
    else
        log_warn "test-scoper not found — skipping scoped tests"
    fi

    # Step 4: Skill validation (runs when skills or framework files change)
    # Moved from CI-only (where failures went unnoticed for weeks) to local
    # pre-commit (where failures block immediately). See contribution model seed.
    local staged_files
    staged_files=$(git diff --cached --name-only)
    local run_skill_validation=false

    # Run skill validation if any skill, hookify, or framework file changed
    if echo "$staged_files" | grep -qE '^\.claude/skills/|^claude/hookify/|^claude/hooks/|^claude/tools/|^claude/CLAUDE-'; then
        run_skill_validation=true
    fi

    if [[ "$run_skill_validation" == "true" ]]; then
        local skill_validation="$REPO_ROOT/tests/skills/skill-validation.bats"
        if [[ -f "$skill_validation" ]]; then
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "[dry-run] Would run: skill-validation.bats"
            else
                log_info "Running skill validation..."
                unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE 2>/dev/null || true
                local sv_output
                if sv_output=$(run_with_timeout 30 bats "$skill_validation" 2>&1); then
                    log_info "Skill validation passed"
                else
                    local sv_exit=$?
                    if [[ $sv_exit -eq 124 ]]; then
                        log_warn "Skill validation timed out (allowing commit)"
                        echo "WARNING: Skill validation timed out"
                    else
                        end_run "failure" "Skill validation failed"
                        echo "Skill validation failed"
                        echo "$sv_output" | tail -20
                        echo "✗"
                        exit 2
                    fi
                fi
            fi
        fi
    fi

    # Step 5: Stage-hash check (warn-only)
    local stage_hash_tool="$SCRIPT_DIR/stage-hash"
    if [[ -x "$stage_hash_tool" && "$DRY_RUN" != "true" ]]; then
        local current_hash
        current_hash=$("$stage_hash_tool" 2>/dev/null || true)
        if [[ -n "$current_hash" ]]; then
            log_info "Stage hash: $current_hash"
            # Check for matching QGR receipt (warn-only, don't block)
            local qgr_match
            qgr_match=$(ls usr/jordan/*/qgr-*-"$current_hash"-*.md 2>/dev/null | head -1 || true)
            if [[ -z "$qgr_match" ]]; then
                log_warn "No QGR receipt for stage hash $current_hash (warn-only)"
            fi
        fi
    fi

    end_run "success" "All checks passed ($classification)"
    echo "All pre-commit checks passed"
    echo "✓"
}

main "$@"
