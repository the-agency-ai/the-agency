#!/bin/bash
#
# stage-hash — Compute deterministic hash of git staging area
#
# Wraps the TypeScript implementation at tools/stage-hash.ts.
# The hash ties QGR receipt files to specific staged content.
#
# Usage:
#   ./claude/tools/stage-hash          # prints 7-char hash
#   ./claude/tools/stage-hash --json   # prints JSON with hash, fileCount, files
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
# shellcheck source=lib/_log-helper
source "$SCRIPT_DIR/lib/_log-helper"

RUN_ID=$(log_start "stage-hash" "$@")
START_MS=$(date +%s%3N 2>/dev/null || date +%s000)

cd "$PROJECT_ROOT"

OUTPUT=$(tsx tools/stage-hash.ts "$@" 2>&1) || {
  EXIT_CODE=$?
  END_MS=$(date +%s%3N 2>/dev/null || date +%s000)
  DURATION=$(( END_MS - START_MS ))
  log_end "$RUN_ID" "error" "$EXIT_CODE" "$DURATION" "$OUTPUT"
  echo "$OUTPUT" >&2
  exit $EXIT_CODE
}

END_MS=$(date +%s%3N 2>/dev/null || date +%s000)
DURATION=$(( END_MS - START_MS ))
log_end "$RUN_ID" "success" "0" "$DURATION" "stage-hash computed"

echo "$OUTPUT"
