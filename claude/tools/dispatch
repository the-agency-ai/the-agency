#!/bin/bash
#
# dispatch — Read and manage dispatches from master
#
# Usage:
#   dispatch list                          — list dispatches for current project
#   dispatch list --all                    — list dispatches across all projects
#   dispatch check                         — SessionStart hook: notify of unread dispatches
#   dispatch read <file>                   — display dispatch and mark as read on master
#   dispatch status <file> <status>        — update dispatch status on master
#   dispatch resolve <file>                — mark dispatch as resolved on master
#   dispatch --version                     — show version
#   dispatch --help                        — show help
#
# Dispatches live on master. Worktree agents read via git show master:
# and write status updates directly to master's working tree.
# The dispatch file's frontmatter tracks its lifecycle:
#   created → read → in-progress → resolved

set -euo pipefail

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source log helper if available
if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi

# --- Resolve paths ---
# Main checkout (master's working tree) — always the first worktree listed
MAIN_CHECKOUT=$(git worktree list | head -1 | awk '{print $1}')

# Principal from agency.yaml
AGENCY_YAML="$MAIN_CHECKOUT/claude/config/agency.yaml"
if [[ -f "$AGENCY_YAML" ]]; then
    PRINCIPAL=$(grep '^principal:' "$AGENCY_YAML" | awk '{print $2}')
else
    PRINCIPAL="jordan"
fi

USR_DIR="claude/usr/$PRINCIPAL"

# Current project — derive from branch name or worktree directory
detect_project() {
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "")

    # If on a worktree, use the worktree directory name
    local git_dir
    git_dir=$(git rev-parse --git-dir 2>/dev/null)
    if [[ "$git_dir" == *"/worktrees/"* ]]; then
        basename "$(git rev-parse --show-toplevel 2>/dev/null)"
        return
    fi

    # On master — captain project
    if [[ "$branch" == "master" || "$branch" == "main" ]]; then
        echo "captain"
        return
    fi

    # Strip common prefixes
    echo "$branch" | sed 's|^proto/||;s|^feature/||;s|^tools/||;s|^worktree-||'
}

# --- Frontmatter helpers ---

# Read a frontmatter field from dispatch content (stdin)
# Returns empty string if field or frontmatter doesn't exist
read_field() {
    local field="$1"
    local result
    result=$(sed -n '/^---$/,/^---$/p' | grep "^${field}:" | head -1 | sed "s/^${field}:[[:space:]]*//" || true)
    echo "${result:-}"
}

# Update a frontmatter field in a file on master's working tree
update_field() {
    local file="$1"
    local field="$2"
    local value="$3"
    local master_file="$MAIN_CHECKOUT/$file"

    if [[ ! -f "$master_file" ]]; then
        echo "dispatch: error: file not found on master: $file" >&2
        return 1
    fi

    # Use sed to update the field in frontmatter
    if grep -q "^${field}:" "$master_file"; then
        sed -i '' "s|^${field}:.*|${field}: ${value}|" "$master_file"
    else
        # Insert before closing --- of frontmatter
        sed -i '' "/^---$/,/^---$/{
            /^---$/{
                N
                /^---\n---$/! b
                i\\
${field}: ${value}
            }
        }" "$master_file"
    fi
}

# --- Logging ---
RUN_ID=""
START_TIME=""

init_logging() {
    local subcmd="$1"
    shift
    if type log_start &>/dev/null; then
        START_TIME=$(python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null || date +%s)
        RUN_ID=$(log_start "dispatch" "$subcmd" "$@")
    fi
}

finish_logging() {
    local outcome="${1:-success}"
    local summary="${2:-}"
    if [[ -n "$RUN_ID" ]] && type log_end &>/dev/null; then
        local now
        now=$(python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null || date +%s)
        local duration=$(( now - START_TIME ))
        log_end "$RUN_ID" "$outcome" "0" "$duration" "$summary"
    fi
    if [[ -n "$RUN_ID" ]] && type tool_output &>/dev/null; then
        local icon="✓"
        [[ "$outcome" != "success" ]] && icon="✗"
        tool_output "dispatch" "$RUN_ID" "$summary" "$icon"
    fi
}

# --- Subcommands ---

cmd_list() {
    local scope="project"
    local project
    project=$(detect_project)

    if [[ "${1:-}" == "--all" ]]; then
        scope="all"
    fi

    if [[ "$scope" == "all" ]]; then
        # List across all projects
        local projects
        projects=$(git show master:"$USR_DIR" 2>/dev/null | grep '/$' | sed 's|/$||' || true)

        local found=0
        for proj in $projects; do
            local cr_dir="$USR_DIR/$proj/code-reviews"
            local dispatches
            dispatches=$(git show master:"$cr_dir" 2>/dev/null | grep 'dispatch' || true)

            for dispatch in $dispatches; do
                local content
                content=$(git show "master:$cr_dir/$dispatch" 2>/dev/null || continue)
                local status
                status=$(echo "$content" | read_field "status")
                local created
                created=$(echo "$content" | read_field "created")
                printf "%-12s %-20s %-12s %s\n" "${status:-unknown}" "$proj" "${created:-?}" "$cr_dir/$dispatch"
                found=$((found + 1))
            done
        done

        if [[ $found -eq 0 ]]; then
            echo "No dispatches found."
        fi
    else
        # List for current project
        local cr_dir="$USR_DIR/$project/code-reviews"
        local dispatches
        dispatches=$(git show master:"$cr_dir" 2>/dev/null | grep 'dispatch' || true)

        if [[ -z "$dispatches" ]]; then
            echo "No dispatches for project: $project"
            return
        fi

        printf "%-12s %-20s %s\n" "STATUS" "CREATED" "FILE"
        printf "%s\n" "────────────────────────────────────────────────────"

        for dispatch in $dispatches; do
            local content
            content=$(git show "master:$cr_dir/$dispatch" 2>/dev/null || continue)
            local status
            status=$(echo "$content" | read_field "status")
            local created
            created=$(echo "$content" | read_field "created")
            printf "%-12s %-20s %s\n" "${status:-unknown}" "${created:-?}" "$cr_dir/$dispatch"
        done
    fi
}

cmd_check() {
    # SessionStart hook — list unread dispatches across all projects
    local projects
    projects=$(git show master:"$USR_DIR" 2>/dev/null | grep '/$' | sed 's|/$||' || true)

    local unread=0
    local unread_list=""

    for proj in $projects; do
        local cr_dir="$USR_DIR/$proj/code-reviews"
        local dispatches
        dispatches=$(git show master:"$cr_dir" 2>/dev/null | grep 'dispatch' || true)

        for dispatch in $dispatches; do
            local content
            content=$(git show "master:$cr_dir/$dispatch" 2>/dev/null || continue)
            local status
            status=$(echo "$content" | read_field "status")

            if [[ "$status" == "created" || -z "$status" ]]; then
                unread=$((unread + 1))
                unread_list="${unread_list}\n  - $cr_dir/$dispatch ($proj)"
            fi
        done
    done

    if [[ $unread -gt 0 ]]; then
        echo "{\"systemMessage\":\"You have $unread unread dispatch(es):${unread_list}\nRead them with: dispatch read <file>\"}"
    fi
    # Silent if no unread dispatches
}

cmd_read() {
    local file="${1:-}"
    if [[ -z "$file" ]]; then
        echo "dispatch: error: usage: dispatch read <file>" >&2
        return 1
    fi

    # Read from master
    local content
    content=$(git show "master:$file" 2>/dev/null)
    if [[ -z "$content" ]]; then
        echo "dispatch: error: file not found on master: $file" >&2
        return 1
    fi

    # Display content
    echo "$content"

    # Mark as read on master's working tree
    local now
    now=$(date -u +"%Y-%m-%dT%H:%M")
    local agent_name
    agent_name=$(git branch --show-current 2>/dev/null || echo "unknown")

    update_field "$file" "status" "read"
    update_field "$file" "read_by" "$agent_name"
    update_field "$file" "read_at" "$now"

    echo ""
    echo "dispatch: marked as read by $agent_name at $now"
}

cmd_status() {
    local file="${1:-}"
    local new_status="${2:-}"

    if [[ -z "$file" || -z "$new_status" ]]; then
        echo "dispatch: error: usage: dispatch status <file> <status>" >&2
        return 1
    fi

    local valid_statuses="created read in-progress resolved"
    if [[ ! " $valid_statuses " =~ " $new_status " ]]; then
        echo "dispatch: error: invalid status '$new_status'. Must be one of: $valid_statuses" >&2
        return 1
    fi

    update_field "$file" "status" "$new_status"
    echo "dispatch: status updated to '$new_status' for $file"
}

cmd_resolve() {
    local file="${1:-}"

    if [[ -z "$file" ]]; then
        echo "dispatch: error: usage: dispatch resolve <file>" >&2
        return 1
    fi

    local master_file="$MAIN_CHECKOUT/$file"
    if [[ ! -f "$master_file" ]]; then
        echo "dispatch: error: file not found on master: $file" >&2
        return 1
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M")

    update_field "$file" "status" "resolved"
    update_field "$file" "resolved_at" "$now"

    echo "dispatch: marked as resolved at $now"
    echo "dispatch: agent should now append Resolution table to $master_file"
}

cmd_help() {
    cat <<'HELP'
dispatch — Read and manage dispatches from master

Usage:
  dispatch list [--all]            List dispatches (current project or all)
  dispatch check                   SessionStart hook: notify of unread
  dispatch read <file>             Display dispatch, mark as read on master
  dispatch status <file> <status>  Update status (created|read|in-progress|resolved)
  dispatch resolve <file>          Mark as resolved on master
  dispatch --version               Show version
  dispatch --help                  Show this help

Dispatches are read from master via git show. Status updates are written
directly to master's working tree. The captain commits them on next sync.
HELP
}

# --- Main ---
subcmd="${1:-}"
case "$subcmd" in
    list)
        init_logging "list" "${@:2}"
        shift; cmd_list "$@"
        finish_logging "success" "Listed dispatches"
        ;;
    check)
        init_logging "check"
        cmd_check
        finish_logging "success" "Checked for unread dispatches"
        ;;
    read)
        init_logging "read" "${2:-}"
        shift; cmd_read "$@"
        finish_logging "success" "Read: ${1:-}"
        ;;
    status)
        init_logging "status" "${2:-}" "${3:-}"
        shift; cmd_status "$@"
        finish_logging "success" "Status → ${2:-}"
        ;;
    resolve)
        init_logging "resolve" "${2:-}"
        shift; cmd_resolve "$@"
        finish_logging "success" "Resolved: ${1:-}"
        ;;
    --version) echo "dispatch $VERSION" ;;
    --help|-h) cmd_help ;;
    *)
        if [[ -n "$subcmd" ]]; then
            echo "dispatch: unknown command '$subcmd'" >&2
        fi
        cmd_help
        exit 1
        ;;
esac
