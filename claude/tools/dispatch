#!/bin/bash
#
# dispatch — ISCP dispatch lifecycle tool (v2)
#
# What Problem: Agents need to send, receive, and track structured messages
# (dispatches) across session boundaries. The v1 tool used git show master:
# and file-path arguments, breaking in worktrees and requiring manual path
# management. v2 uses the ISCP SQLite DB as the index, with payloads still
# in git for human readability and version control.
#
# How & Why: Single tool with subcommands (create, list, read, check, resolve,
# status). The DB tracks metadata/state; git stores the payload file. The
# `create` subcommand merges the former dispatch-create tool (per A&D spec).
# Identity resolved via agent-identity tool. Payload paths resolved from DB,
# not constructed by the caller. Arguments take integer dispatch IDs, not
# file paths — the DB is the index.
#
# Written: 2026-04-05 during ISCP Iteration 1.4
#
# Usage:
#   dispatch create --to <addr> --subject <text> [--type <type>] [--priority <p>]
#   dispatch list [--all] [--status <s>] [--type <t>]
#   dispatch read <id>
#   dispatch check
#   dispatch resolve <id> [--response <id>]
#   dispatch status <id>
#   dispatch --version
#   dispatch --help
#

set -euo pipefail

TOOL_VERSION="2.0.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Source helpers
source "$SCRIPT_DIR/lib/_log-helper"
source "$SCRIPT_DIR/lib/_path-resolve"
source "$SCRIPT_DIR/lib/_address-parse"
source "$SCRIPT_DIR/lib/_iscp-db"

# Valid dispatch types (must match _iscp-db CHECK constraint)
VALID_TYPES="directive seed review review-response commit master-updated escalation dispatch"

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

# Resolve current agent's identity
_resolve_identity() {
    local identity
    identity=$("$SCRIPT_DIR/agent-identity" 2>/dev/null) || {
        echo "Error: cannot resolve agent identity. Run: agent-identity --help" >&2
        return 1
    }
    echo "$identity"
}

# Resolve main checkout path (for reading payload files from worktrees)
_main_checkout() {
    git worktree list 2>/dev/null | head -1 | awk '{print $1}'
}

# Generate slug from subject
_slugify() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-50
}

# Validate dispatch type
_validate_type() {
    local dtype="$1"
    for valid in $VALID_TYPES; do
        if [[ "$dtype" == "$valid" ]]; then
            return 0
        fi
    done
    echo "Error: invalid dispatch type '$dtype'. Must be one of: $VALID_TYPES" >&2
    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# create — Create dispatch (DB record + git payload file)
# ─────────────────────────────────────────────────────────────────────────────
cmd_create() {
    local to_addr="" subject="" reply_to="" priority="normal" dtype="dispatch" project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --to)
                [[ -n "${2:-}" ]] || { echo "Error: --to requires an address" >&2; return 1; }
                to_addr="$2"; shift 2 ;;
            --subject)
                [[ -n "${2:-}" ]] || { echo "Error: --subject requires text" >&2; return 1; }
                subject="$2"; shift 2 ;;
            --type)
                [[ -n "${2:-}" ]] || { echo "Error: --type requires a type" >&2; return 1; }
                dtype="$2"; shift 2 ;;
            --reply-to)
                [[ -n "${2:-}" ]] || { echo "Error: --reply-to requires a dispatch ID or filename" >&2; return 1; }
                reply_to="$2"; shift 2 ;;
            --priority)
                [[ -n "${2:-}" ]] || { echo "Error: --priority requires a level" >&2; return 1; }
                priority="$2"; shift 2 ;;
            --project)
                [[ -n "${2:-}" ]] || { echo "Error: --project requires a name" >&2; return 1; }
                project="$2"; shift 2 ;;
            --help|-h)
                echo "Usage: dispatch create --to <addr> --subject <text> [--type <type>] [--priority <p>] [--reply-to <id>] [--project <name>]"
                return 0 ;;
            *)
                echo "Error: unknown option for create: $1" >&2; return 1 ;;
        esac
    done

    # Validate required args
    if [[ -z "$to_addr" ]]; then
        echo "Error: --to <address> is required" >&2; return 1
    fi
    if [[ -z "$subject" ]]; then
        echo "Error: --subject <text> is required" >&2; return 1
    fi

    # Validate type
    _validate_type "$dtype" || return 1

    # Validate priority
    case "$priority" in
        normal|high|low) ;;
        *) echo "Error: --priority must be normal, high, or low" >&2; return 1 ;;
    esac

    # Resolve sender identity (auto-computed, never self-asserted — DD-7)
    local from_agent
    from_agent=$(_resolve_identity) || return 1

    # Validate and resolve --to address
    address_resolve "$to_addr" 2>/dev/null || {
        address_parse "$to_addr" || {
            echo "Error: invalid --to address: $to_addr" >&2; return 1
        }
    }
    local to_formatted="$to_addr"
    if [[ -n "$ADDR_REPO" && -n "$ADDR_PRINCIPAL" && -n "$ADDR_AGENT" ]]; then
        to_formatted=$(address_format "$ADDR_REPO" "$ADDR_PRINCIPAL" "$ADDR_AGENT")
    fi

    # Determine project directory for payload
    if [[ -z "$project" ]]; then
        # Default: derive from sender's agent name
        address_parse "$from_agent" 2>/dev/null || true
        project="${ADDR_AGENT:-captain}"
    fi

    # Generate payload file
    local slug timestamp date_full filename
    slug=$(_slugify "$subject")
    [[ -z "$slug" ]] && slug="dispatch"
    timestamp=$(date +%Y%m%d-%H%M)
    date_full=$(date -u +%Y-%m-%dT%H:%M)
    filename="${dtype}-${slug}-${timestamp}.md"

    # Resolve dispatch directory from sender's principal
    address_parse "$from_agent" 2>/dev/null || true
    local dispatch_principal="${ADDR_PRINCIPAL:-${AGENCY_PRINCIPAL:-${USER:-unknown}}}"
    local dispatch_dir="$PROJECT_ROOT/usr/${dispatch_principal}/${project}/dispatches"
    mkdir -p "$dispatch_dir"

    local filepath="$dispatch_dir/$filename"
    # Compute repo-relative path for DB storage
    local payload_path="${filepath#$PROJECT_ROOT/}"

    # Handle reply-to: accept integer ID or filename
    local reply_to_sql="NULL"
    if [[ -n "$reply_to" ]]; then
        if [[ "$reply_to" =~ ^[0-9]+$ ]]; then
            reply_to_sql="$reply_to"
        fi
        # If it's a filename, we store it as-is in frontmatter but don't set FK
    fi

    # Initialize DB (idempotent)
    iscp_db_init

    # Write payload file
    cat > "$filepath" << DISPATCH_EOF
---
type: ${dtype}
from: ${from_agent}
to: ${to_formatted}
date: ${date_full}
status: created
priority: ${priority}
subject: "${subject}"
in_reply_to: ${reply_to:-null}
---

# ${subject}

## Context

<!-- Why this dispatch exists -->

## Directive

<!-- What the receiving agent should do -->

## Acceptance Criteria

- [ ] <!-- criterion 1 -->
DISPATCH_EOF

    # Insert into DB
    local insert_sql="INSERT INTO dispatches (created_at, from_agent, to_agent, type, priority, subject, payload_path, in_reply_to, status)
        VALUES (:created_at, :from_agent, :to_agent, :type, :priority, :subject, :payload_path, ${reply_to_sql}, 'unread')"

    local dispatch_id
    dispatch_id=$(iscp_db_exec "$insert_sql" \
        ":created_at" "$date_full" \
        ":from_agent" "$from_agent" \
        ":to_agent" "$to_formatted" \
        ":type" "$dtype" \
        ":priority" "$priority" \
        ":subject" "$subject" \
        ":payload_path" "$payload_path")

    # Get the actual ID (last_insert_rowid)
    local db_id
    db_id=$(iscp_db_query "SELECT last_insert_rowid()")

    echo "dispatch [create]"
    echo "  ID:   $db_id"
    echo "  File: $payload_path"
    echo "  From: $from_agent"
    echo "  To:   $to_formatted"
    echo "  Type: $dtype"
    echo "✓"
}

# ─────────────────────────────────────────────────────────────────────────────
# Main dispatch — route subcommands
# ─────────────────────────────────────────────────────────────────────────────

cmd_help() {
    cat <<'HELP'
dispatch — ISCP dispatch lifecycle tool (v2)

Usage:
  dispatch create --to <addr> --subject <text> [--type <type>] [--priority <p>]
  dispatch list [--all] [--status <s>] [--type <t>]
  dispatch read <id>
  dispatch check
  dispatch resolve <id> [--response <id>]
  dispatch status <id>
  dispatch --version
  dispatch --help

Dispatch types: directive, seed, review, review-response, commit,
  master-updated, escalation, dispatch

Dispatches are indexed in the ISCP SQLite DB. Payload files live in git.
Arguments take integer dispatch IDs, not file paths.
HELP
}

# --- Main ---
RUN_ID=$(log_start "dispatch" "${1:-}" "${@:2}")

subcmd="${1:-}"
case "$subcmd" in
    create)
        shift; cmd_create "$@"
        log_end "$RUN_ID" "success" "0" "0" "dispatch create"
        ;;
    --version) echo "dispatch $TOOL_VERSION" ;;
    --help|-h) cmd_help ;;
    "")
        cmd_help; exit 1 ;;
    *)
        echo "dispatch: unknown command '$subcmd'" >&2
        echo "Run: dispatch --help" >&2
        exit 1
        ;;
esac
