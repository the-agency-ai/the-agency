#!/bin/bash
#
# handoff — First-class Agency primitive for context bootstrapping
#
# Usage:
#   handoff write [--trigger <name>] [--type <type>]  — auto-archive + signal agent to write
#   handoff write --lightweight [--trigger <name>]    — append status line (no archive)
#   handoff read                                      — output current handoff content
#   handoff path                                      — output handoff file path
#   handoff archive                                   — archive current handoff to history/
#   handoff --version                                 — show version
#   handoff --help                                    — show help
#
# Types (--type):
#   session          — normal session handoff (default)
#   agency-bootstrap — written by agency init, triggers onboarding
#   agency-update    — written by agency update, triggers verification
#
# Handoffs are not just session continuity — they bootstrap context for any
# purpose: agent-to-agent, cold start, project setup, compaction survival.
#
# The tool handles infrastructure (path resolution, archival, signaling).
# The agent writes the actual content.

set -euo pipefail

VERSION="2.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source log helper if available
if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi

# Source address-parse for fully qualified agent address
if [[ -f "$SCRIPT_DIR/lib/_address-parse" ]]; then
    source "$SCRIPT_DIR/lib/_address-parse"
fi

# --- PATH resolution ---
[ -d /opt/homebrew/bin ] && export PATH="/opt/homebrew/bin:$PATH"
[ -d "$HOME/.asdf/shims" ] && export PATH="$HOME/.asdf/shims:$PATH"

# --- Help ---
show_help() {
    echo "Usage: handoff <command> [options]"
    echo ""
    echo "Commands:"
    echo "  write [--trigger <name>] [--type <type>]  Auto-archive + signal agent to write"
    echo "  write --lightweight [--trigger <name>]       Append status line (no archive)"
    echo "  read                                Output current handoff content"
    echo "  path                                Output handoff file path"
    echo "  archive                             Archive current handoff to history/"
    echo ""
    echo "Options:"
    echo "  --version                  Show version"
    echo "  --help                     Show this help"
    echo ""
    echo "Types: session (default), agency-bootstrap, agency-update"
    echo ""
    echo "Triggers: SessionEnd, PreCompact, iteration-complete, phase-complete, plan-complete"
}

# --- Resolve handoff path ---
resolve_path() {
    local project_dir
    if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
        project_dir="$CLAUDE_PROJECT_DIR"
    else
        project_dir=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    fi

    local branch
    branch=$(git -C "$project_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
        echo "" # git failed or detached HEAD — cannot resolve handoff path
        return
    fi
    local slug
    slug="${branch##*/}"
    # Strip worktree- prefix
    slug="${slug#worktree-}"
    # master/main -> captain
    if [ "$slug" = "master" ] || [ "$slug" = "main" ]; then
        slug="captain"
    fi

    # Find principal — prefer $USER match, fall back to first found
    local principal=""
    if [ -d "$project_dir/usr/${USER:-}" ]; then
        principal="$USER"
    else
        local _old_nullglob
        _old_nullglob=$(shopt -p nullglob 2>/dev/null || true)
        shopt -s nullglob
        for dir in "$project_dir"/usr/*/; do
            [ -d "$dir" ] || continue
            local name
            name=$(basename "$dir")
            [ "$name" = "README.md" ] && continue
            principal="$name"
            break
        done
        eval "$_old_nullglob" 2>/dev/null || true
    fi

    if [ -z "$principal" ]; then
        echo ""
        return
    fi

    echo "$project_dir/usr/$principal/$slug/handoff.md"
}

# --- Parse args ---
COMMAND="${1:-}"
shift 2>/dev/null || true

case "$COMMAND" in
    --version|-v)
        echo "handoff $VERSION"
        exit 0
        ;;
    --help|-h)
        show_help
        exit 0
        ;;
    "")
        show_help
        exit 1
        ;;
esac

HANDOFF_PATH=$(resolve_path)
if [ -z "$HANDOFF_PATH" ]; then
    echo "Error: no principal sandbox found in usr/" >&2
    exit 1
fi

# --- Compute fully qualified agent address ---
AGENT_ADDRESS=""
if type address_resolve &>/dev/null; then
    # Derive agent name from branch (same logic as resolve_path)
    _agent_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
    _agent_slug="${_agent_branch##*/}"
    _agent_slug="${_agent_slug#worktree-}"
    case "$_agent_slug" in
        main|master) _agent_slug="captain" ;;
    esac
    # Use CLAUDE_AGENT_NAME if available (future: Claude Code may expose this)
    _agent_name="${CLAUDE_AGENT_NAME:-$_agent_slug}"
    if address_resolve "$_agent_name" 2>/dev/null; then
        AGENT_ADDRESS=$(address_format 2>/dev/null) || true
    fi
fi

TRIGGER=""
LIGHTWEIGHT=false
HANDOFF_TYPE="session"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --trigger)
            [[ -n "${2:-}" ]] || { echo "Error: --trigger requires a value" >&2; exit 1; }
            # Sanitize trigger to alphanumeric, hyphens, underscores only
            TRIGGER=$(printf '%s' "$2" | tr -cd 'A-Za-z0-9_-')
            shift 2
            ;;
        --type)
            [[ -n "${2:-}" ]] || { echo "Error: --type requires a value" >&2; exit 1; }
            HANDOFF_TYPE="$2"
            shift 2
            ;;
        --lightweight) LIGHTWEIGHT=true; shift ;;
        *) shift ;;
    esac
done

TIMESTAMP=$(date '+%Y-%m-%d %H:%M')

# --- Start logging at top level (consistent with agent-define pattern) ---
RUN_ID=""
if type log_start &>/dev/null; then
    RUN_ID=$(log_start "handoff" "$COMMAND --trigger ${TRIGGER:-manual}")
fi

# --- Helper: archive existing handoff ---
_do_archive() {
    if [ -f "$HANDOFF_PATH" ]; then
        local history_dir
        history_dir="$(dirname "$HANDOFF_PATH")/history"
        mkdir -p "$history_dir"
        local archive_name="handoff-$(date '+%Y%m%d-%H%M%S').md"
        cp "$HANDOFF_PATH" "$history_dir/$archive_name"
    fi
}

case "$COMMAND" in
    write)
        if [ "$LIGHTWEIGHT" = true ]; then
            # Lightweight mode: append/update status line, no archive
            if [ -f "$HANDOFF_PATH" ]; then
                sync_line="Last sync: ${TIMESTAMP} (via ${TRIGGER:-manual})"
                if grep -q "^Last sync:" "$HANDOFF_PATH" 2>/dev/null; then
                    tmp=$(mktemp "$(dirname "$HANDOFF_PATH")/handoff.XXXXXX")
                    trap 'rm -f "$tmp"' EXIT
                    if sed "s|^Last sync:.*|${sync_line}|" "$HANDOFF_PATH" > "$tmp"; then
                        mv "$tmp" "$HANDOFF_PATH"
                    else
                        rm -f "$tmp"
                    fi
                    trap - EXIT
                else
                    printf '\n%s\n' "$sync_line" >> "$HANDOFF_PATH"
                fi
            fi
            if [ -n "$RUN_ID" ]; then
                tool_output "handoff" "$RUN_ID" "Sync: ${HANDOFF_PATH##*/usr/}"
            else
                echo "handoff"
                echo "Sync: ${HANDOFF_PATH##*/usr/}"
                echo "✓"
            fi
        else
            # Full write: auto-archive existing, then signal agent
            _do_archive

            # For hook triggers, output JSON systemMessage
            if [ "$TRIGGER" = "SessionEnd" ] || [ "$TRIGGER" = "PreCompact" ]; then
                AGENT_MSG=""
                if [ -n "$AGENT_ADDRESS" ]; then
                    AGENT_MSG=" Include agent: ${AGENT_ADDRESS} in YAML frontmatter."
                fi
                MSG="Handoff trigger: ${TRIGGER} at ${TIMESTAMP}. Update ${HANDOFF_PATH##*/usr/} with current session state before the session ends. Use type: ${HANDOFF_TYPE} in YAML frontmatter.${AGENT_MSG}"
                command -v jq >/dev/null 2>&1 && {
                    printf '{"systemMessage":%s}' "$(printf '%s' "$MSG" | jq -Rs '.')"
                } || {
                    printf '{"systemMessage":"%s"}' "$MSG"
                }
            else
                # For manual/command triggers, plain output
                AGENT_INFO=""
                if [ -n "$AGENT_ADDRESS" ]; then
                    AGENT_INFO=", agent: ${AGENT_ADDRESS}"
                fi
                if [ -n "$RUN_ID" ]; then
                    tool_output "handoff" "$RUN_ID" "Write: ${HANDOFF_PATH##*/usr/} (trigger: ${TRIGGER:-manual}, type: ${HANDOFF_TYPE}${AGENT_INFO})"
                else
                    echo "handoff [run: ${RUN_ID:-none}]"
                    echo "Write: ${HANDOFF_PATH##*/usr/} (trigger: ${TRIGGER:-manual}, type: ${HANDOFF_TYPE}${AGENT_INFO})"
                    echo "✓"
                fi
            fi
        fi

        # log_end unconditionally — covers both hook and non-hook paths
        if [ -n "$RUN_ID" ]; then
            log_end "$RUN_ID" "success" 0 0 "write triggered (${TRIGGER:-manual})"
        fi
        ;;

    read)
        if [ -f "$HANDOFF_PATH" ]; then
            cat "$HANDOFF_PATH"
            if [ -n "$RUN_ID" ]; then
                log_end "$RUN_ID" "success" 0 0 "read handoff"
            fi
        else
            echo "No handoff found at ${HANDOFF_PATH##*/usr/}"
            if [ -n "$RUN_ID" ]; then
                log_end "$RUN_ID" "failure" 1 0 "no handoff found"
            fi
            exit 1
        fi
        ;;

    path)
        echo "$HANDOFF_PATH"
        if [ -n "$RUN_ID" ]; then
            log_end "$RUN_ID" "success" 0 0 "path resolved"
        fi
        ;;

    archive)
        if [ ! -f "$HANDOFF_PATH" ]; then
            echo "No handoff to archive at ${HANDOFF_PATH##*/usr/}"
            if [ -n "$RUN_ID" ]; then
                log_end "$RUN_ID" "failure" 1 0 "no handoff to archive"
            fi
            exit 1
        fi

        _do_archive
        ARCHIVE_NAME="handoff-$(date '+%Y%m%d-%H%M%S').md"

        if [ -n "$RUN_ID" ]; then
            log_end "$RUN_ID" "success" 0 0 "archived to history/"
            tool_output "handoff" "$RUN_ID" "Archived: history/$ARCHIVE_NAME"
        else
            echo "handoff"
            echo "Archived: history/$ARCHIVE_NAME"
            echo "✓"
        fi
        ;;

    *)
        echo "Error: unknown command '$COMMAND'" >&2
        show_help >&2
        exit 1
        ;;
esac

exit 0
