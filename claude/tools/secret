#!/bin/bash
#
# secret — Top-level wrapper for SPEC-PROVIDER secret management
#
# What Problem: The /secret skill dispatches to ./claude/tools/secret-{provider}
# based on agency.yaml's secrets.provider config — but only inside Claude Code
# sessions. Shell scripts, CI pipelines, and dev tools that want to use the
# secret subsystem can't invoke a skill — they need a CLI tool. Without a
# top-level wrapper, the SPEC-PROVIDER pattern is incomplete: the skill
# (discovery layer) exists, the providers (implementation layer) exist, but
# there's no tool (mechanical layer) for non-agent contexts.
#
# Additionally, tests/tools/secret.bats was written assuming a top-level
# `./claude/tools/secret` tool — those 31 tests have been failing because the
# tool was missing. The pre-commit hook runs the full BATS suite and the
# failing secret.bats blocks all worktree commits.
#
# How & Why: Thin pass-through dispatcher. Reads `secrets.provider` from
# claude/config/agency.yaml, defaults to `vault`, then execs the corresponding
# provider tool (`./claude/tools/secret-{provider}`) with all args forwarded.
# Using `exec` instead of subshell so signals (Ctrl+C, etc.) propagate
# correctly and the wrapper has zero process overhead.
#
# Provider resolution: simple awk parse of agency.yaml. No yaml library
# dependency — keeps the wrapper portable to any environment with bash + awk.
# Falls back to `vault` if no provider configured (matches the framework
# default in settings-template.json and agency.yaml).
#
# This completes the SPEC-PROVIDER triangle for the secret capability:
#   - Skill:    .claude/skills/secret/SKILL.md (agent invocation, /secret)
#   - Tool:     claude/tools/secret             (this file — CLI wrapper)
#   - Provider: claude/tools/secret-{provider}  (vault, doppler, etc.)
#
# The same pattern applies to /preview and /deploy when those wrappers
# get built later (they currently have skill + provider but no top-level
# wrapper either). They were intentionally not built in this PR — we need
# to confirm the pattern works for /secret first, and the bigger SPEC-PROVIDER
# structural question is open (see captain's thoughts dispatch to monofolk/devex).
#
# Written: 2026-04-07 — Day 32 - Release 3 — flag #34 follow-up

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- PATH resolution (for non-login shells) ---
[ -d /opt/homebrew/bin ] && export PATH="/opt/homebrew/bin:$PATH"

# --- Resolve project root ---
# CLAUDE_PROJECT_DIR is set inside Claude Code hooks but NOT in agent Bash
# tool calls. Fall back to git rev-parse for worktree detection, then
# SCRIPT_DIR-based fallback for non-git contexts.
if [[ -n "${CLAUDE_PROJECT_DIR:-}" ]]; then
    PROJECT_ROOT="$CLAUDE_PROJECT_DIR"
elif PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    :
else
    PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
fi

# --- Resolve provider from agency.yaml ---
# Looks for: secrets.provider: "name" — handles quoted and unquoted forms.
# Default: vault (matches framework default).
AGENCY_YAML="$PROJECT_ROOT/claude/config/agency.yaml"
PROVIDER="vault"

if [[ -f "$AGENCY_YAML" ]]; then
    _resolved=$(awk '
        /^secrets:/ { in_secrets=1; next }
        in_secrets && /^[a-z]/ { in_secrets=0 }
        in_secrets && /^  provider:/ {
            gsub(/^  provider: *"?/, "")
            gsub(/"? *(#.*)?$/, "")
            print
            exit
        }
    ' "$AGENCY_YAML" 2>/dev/null || echo "")
    [[ -n "$_resolved" ]] && PROVIDER="$_resolved"
fi

# --- Dispatch to provider tool ---
PROVIDER_TOOL="$SCRIPT_DIR/secret-$PROVIDER"

if [[ ! -x "$PROVIDER_TOOL" ]]; then
    echo "Error: secret provider '$PROVIDER' not available at $PROVIDER_TOOL" >&2
    echo "" >&2
    echo "Available providers:" >&2
    for tool in "$SCRIPT_DIR"/secret-*; do
        [[ -x "$tool" ]] || continue
        # Skip non-provider tools like secret-migrate, secrets-scan
        case "$(basename "$tool")" in
            secret-vault|secret-doppler) echo "  - $(basename "$tool" | sed 's/secret-//')" >&2 ;;
        esac
    done
    echo "" >&2
    echo "Configure in: $AGENCY_YAML (secrets.provider: <name>)" >&2
    exit 1
fi

exec "$PROVIDER_TOOL" "$@"
