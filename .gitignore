# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Service logs (in each service directory)
services/*/logs/*.log
services/*/logs/*.json

# Database files
agency/config/*.db
agency/config/*.db-wal
agency/config/*.db-shm

# Instance tracking (ephemeral runtime state)
agency/config/instances/

# Service PID files (runtime)
agency/config/*.pid

# C#372 Fix B — pending-post-merge state (captain-local ephemeral state)
agency/config/post-merge-pending.json

# Agency service logs (but keep reviews for findings history)
agency/logs/*
!agency/logs/reviews/

# Tool telemetry (local runtime logs)
.claude/logs/

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Principal secrets (never commit)
usr/*/resources/secrets/
claude/apps/AgencyBench.app
test/

# BATS test pollution guards (#387, #384, #390)
# These catch test leaks at the commit boundary so they can't reach git
# even if a BATS helper escapes its sandbox. Until #384 (Docker-isolated
# BATS) lands, these gitignore entries are the second line of defense.
# If a test genuinely needs to create one of these paths, it should run
# inside $BATS_TEST_TMPDIR, not in $REPO_ROOT.
agency/agents/testname/
usr/*/testname/
usr/*/testjordan/
.claude/agents/*/testname.md
agency/workstreams/housekeeping/
agency/workstreams/test*
# Pathological test fixture names (leaked via unquoted command substitution)
/On branch main*
**/tmp.*/fixture/
# Test-auto QGR fixtures (bats produces these on each run)
agency/workstreams/*/qgr/test-*-test-auto-*.md
agency/workstreams/*/rgr/test-*-test-auto-*.md

# Claude Code local settings (user customizations)
.claude/settings.local.json

# Worktrees (parallel agent sessions — ephemeral, not versioned)
.claude/worktrees/
.worktrees/

# Session backups (ephemeral state - not versioned)
agency/agents/*/backups/latest/
agency/agents/*/backups/archive/
agency/agents/*/backups/
agency/agents/*/logs/
agency/agents/unknown/

# Services (local development - root level only, not source/services)
/services/

# Agency local data (not versioned)
.agency/projects.json

# Agent identity marker (runtime state — set per-worktree, not versioned)
.agency-agent

# Python bytecode (generated by running framework Python tools)
__pycache__/
*.pyc
*.pyo
*.pyd

# Scheduled tasks lock (runtime state)
.claude/scheduled_tasks.lock

# --- The Agency framework-managed ignores ---
# Managed by `agency init` / `agency update`. Append your project-specific
# ignores above or below this block; leave these lines intact.

# Tool telemetry (runtime logs, auto-appended — never commit)
.claude/logs/

# Agency service logs (but keep reviews for findings history)
agency/logs/*
!agency/logs/reviews/

# Principal scratch (gitignored intentionally — used for drafts, tmp files)
usr/*/tmp/
usr/*/*/tmp/

# Temporary agent/tool scratch
.cache/
*.tmp
*.temp
# --- End framework-managed ignores ---
