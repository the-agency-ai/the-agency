#!/bin/bash
# launch-project - Launch into a project in a new Ghostty tab
#
# Usage:
#   ./agency/tools/launch-project /path/to/project
#   ./agency/tools/launch-project my-project  # Looks up in projects.json
#
# Requires: macOS + Ghostty

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STARTER_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Colors
if [[ -f "$SCRIPT_DIR/lib/_colors" ]]; then
    source "$SCRIPT_DIR/lib/_colors"
else
    RED="[0;31m" GREEN="[0;32m" YELLOW="[1;33m" BLUE="[0;34m" NC="[0m"
fi

# Help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || -z "${1:-}" ]]; then
    echo "launch-project - Launch into a project in a new Ghostty tab"
    echo ""
    echo "Usage:"
    echo "  ./agency/tools/launch-project /path/to/project"
    echo "  ./agency/tools/launch-project my-project  # Looks up in projects.json"
    echo ""
    echo "Requires: macOS + Ghostty"
    exit 0
fi

PROJECT_INPUT="$1"
PROJECT_PATH=""
PROJECT_NAME=""

# Check if it's an absolute path
if [[ "$PROJECT_INPUT" == /* ]]; then
    PROJECT_PATH="$PROJECT_INPUT"
    PROJECT_NAME=$(basename "$PROJECT_PATH")
elif [[ -d "$PROJECT_INPUT" ]]; then
    PROJECT_PATH="$(cd "$PROJECT_INPUT" && pwd)"
    PROJECT_NAME=$(basename "$PROJECT_PATH")
else
    # Look up in projects.json
    PROJECTS_FILE="$STARTER_DIR/.agency/projects.json"
    if [[ -f "$PROJECTS_FILE" ]]; then
        PROJECT_PATH=$(python3 -c "
import json, sys
with open('$PROJECTS_FILE') as f:
    data = json.load(f)
for p in data.get('projects', []):
    if p['name'] == '$PROJECT_INPUT':
        print(p['path'])
        sys.exit(0)
sys.exit(1)
" 2>/dev/null) || true
        PROJECT_NAME="$PROJECT_INPUT"
    fi
fi

if [[ -z "$PROJECT_PATH" || ! -d "$PROJECT_PATH" ]]; then
    echo -e "${RED}Error:${NC} Project not found: $PROJECT_INPUT"
    echo "Provide a path or a project name registered in .agency/projects.json"
    exit 1
fi

# Check for Ghostty
if ! command -v ghostty &>/dev/null && [[ ! -d "/Applications/Ghostty.app" ]]; then
    echo -e "${RED}Error:${NC} Ghostty not found"
    exit 1
fi

echo -e "${GREEN}Launching:${NC} $PROJECT_NAME"
echo -e "${GREEN}Path:${NC} $PROJECT_PATH"

# Open new Ghostty window/tab via the CLI
# ghostty +new-window spawns a new window; redirect stdin so it detaches cleanly
ghostty --working-directory="$PROJECT_PATH" --command="bash -c 'exec ./agency/tools/myclaude housekeeping captain'" 2>/dev/null &
disown 2>/dev/null || true

echo -e "${GREEN}Done!${NC} Ghostty window opened for $PROJECT_NAME"
