# _agency-verify — Validate Agency configuration and provider setup
#
# Sourced by: agency verify [--verbose]
# Arguments via: AGENCY_ARGS array
# Inherits: set -euo pipefail, AGENCY_DIR, _log-helper, colors

RUN_ID=$(log_start "agency-verify" "${AGENCY_ARGS[@]+"${AGENCY_ARGS[@]}"}" 2>/dev/null) || true

PROJECT_ROOT="$(cd "$AGENCY_DIR/.." && pwd)"

# Parse args
VERBOSE=false
for arg in "${AGENCY_ARGS[@]+"${AGENCY_ARGS[@]}"}"; do
    case "$arg" in
        --help|-h)
            echo "agency verify — Validate Agency configuration"
            echo ""
            echo "Usage: agency verify [--verbose]"
            echo ""
            echo "Checks provider configuration, required files, and directories."
            exit 0
            ;;
        --verbose|-v) VERBOSE=true ;;
    esac
done

verbose() { [[ "$VERBOSE" == "true" ]] && echo -e "$@" || true; }

PASS=0
FAIL=0
WARN=0

check_pass() {
    PASS=$((PASS + 1))
    verbose "${GREEN}  ✓${NC} $1"
}

check_fail() {
    FAIL=$((FAIL + 1))
    verbose "${RED}  ✗${NC} $1"
}

check_warn() {
    WARN=$((WARN + 1))
    verbose "${YELLOW}  △${NC} $1"
}

echo "agency verify [run: ${RUN_ID:-none}]"

# --- Check agency.yaml ---
YAML="$PROJECT_ROOT/agency/config/agency.yaml"
if [[ -f "$YAML" ]]; then
    check_pass "agency.yaml exists"
else
    check_fail "agency.yaml not found at $YAML"
fi

# --- Check provider tools ---
if [[ -f "$PROJECT_ROOT/claude/tools/lib/_provider-resolve" ]]; then
    source "$PROJECT_ROOT/claude/tools/lib/_provider-resolve"
    check_pass "_provider-resolve loaded"
else
    check_fail "_provider-resolve not found"
fi

# Check each provider section
for section in secrets terminal platform; do
    provider_name=$(get_provider_name "$section" 2>/dev/null) || true

    if [[ -z "$provider_name" ]]; then
        check_warn "$section: no provider configured"
        continue
    fi

    # Platform "auto" is valid — resolve to actual OS
    if [[ "$section" == "platform" && "$provider_name" == "auto" ]]; then
        case "$(uname -s)" in
            Darwin) provider_name="macos" ;;
            Linux)  provider_name="linux" ;;
            *)      check_warn "$section: auto-detect unsupported for $(uname -s)"; continue ;;
        esac
    fi

    tool_name=$(_provider_tool_name "$section" "$provider_name" 2>/dev/null) || true
    tool_path="$PROJECT_ROOT/claude/tools/$tool_name"

    if [[ -x "$tool_path" ]]; then
        check_pass "$section: $tool_name"
    elif [[ -f "$tool_path" ]]; then
        check_fail "$section: $tool_name exists but not executable"
    else
        check_fail "$section: $tool_name not found"
    fi
done

# Design verbs
for verb in diff extract; do
    provider_name=$(get_provider_name "design" 2>/dev/null) || true
    if [[ -n "$provider_name" ]]; then
        tool_name=$(_provider_tool_name "design" "$provider_name" "$verb" 2>/dev/null) || true
        tool_path="$PROJECT_ROOT/claude/tools/$tool_name"
        if [[ -x "$tool_path" ]]; then
            check_pass "design.$verb: $tool_name"
        elif [[ -f "$tool_path" ]]; then
            check_fail "design.$verb: $tool_name exists but not executable"
        else
            check_warn "design.$verb: $tool_name not found (deferred)"
        fi
    fi
done

# --- Check required directories ---
for dir in claude/config claude/agents claude/docs claude/hooks; do
    if [[ -d "$PROJECT_ROOT/$dir" ]]; then
        check_pass "directory: $dir/"
    else
        check_fail "directory: $dir/ missing"
    fi
done

# --- Check agency CLI exists ---
if [[ -x "$PROJECT_ROOT/claude/tools/agency" ]]; then
    check_pass "agency CLI"
else
    check_fail "agency CLI not found or not executable"
fi

# --- Summary ---
TOTAL=$((PASS + FAIL + WARN))
if [[ $FAIL -eq 0 ]]; then
    echo "$PASS/$TOTAL checks passed ($WARN warnings)"
    echo "✓"
    log_end "$RUN_ID" "success" 0 0 "$PASS/$TOTAL passed" 2>/dev/null || true
else
    echo "$PASS/$TOTAL checks passed, $FAIL failed ($WARN warnings)"
    echo "✗"
    log_end "$RUN_ID" "failure" 1 0 "$FAIL failures" 2>/dev/null || true
    exit 1
fi
