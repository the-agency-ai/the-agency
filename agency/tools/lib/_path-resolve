#!/bin/bash
#
# _path-resolve - Shared helper for principal path resolution
#
# Source this file in tools/hooks to resolve principal-specific paths.
# Follows the same pattern as _log-helper: sourced, silent, non-blocking.
#
# Usage:
#   source "$(dirname "$0")/_path-resolve"
#
#   # After sourcing, these are available:
#   echo "$AGENCY_PRINCIPAL"       # Principal name (e.g., "jordan")
#   echo "$AGENCY_PRINCIPAL_DIR"   # Full path (e.g., "/path/to/project/usr/jordan")
#   echo "$AGENCY_REFS_DIR"        # Refs dir (e.g., "/path/to/project/usr/jordan/claude/refs")
#   echo "$AGENCY_PROJECT_ROOT"    # Project root
#
# Resolution order:
#   1. AGENCY_PRINCIPAL env var (already set)
#   2. Map $USER via agency.yaml principals section
#   3. Fall back to "default" mapping in agency.yaml
#
# The helper will silently use defaults if:
#   - agency.yaml is missing
#   - No mapping is found
#   - Any parsing fails
#

# Find project root (walk up from script location)
_pr_find_root() {
    local dir="${1:-$(pwd)}"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/agency/config/agency.yaml" ]]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    # Fallback: try CLAUDE_PROJECT_DIR
    if [[ -n "${CLAUDE_PROJECT_DIR:-}" ]] && [[ -f "$CLAUDE_PROJECT_DIR/claude/config/agency.yaml" ]]; then
        echo "$CLAUDE_PROJECT_DIR"
        return 0
    fi
    return 1
}

# Parse a simple key from agency.yaml (avoids yq/python dependency)
# Usage: _pr_yaml_get "principals" "jdm"
# Looks for lines like "  jdm: jordan" under the principals: section
_pr_yaml_get() {
    local section="$1"
    local key="$2"
    local yaml_file="$3"

    local in_section=false
    local found_key=false
    while IFS= read -r line; do
        # Detect section header (no leading whitespace)
        if [[ "$line" =~ ^[a-zA-Z] ]]; then
            if [[ "$line" =~ ^${section}: ]]; then
                in_section=true
            else
                # If we found the key but are in nested mode, we never got a name field
                in_section=false
            fi
            found_key=false
            continue
        fi
        # In section, look for key
        if [[ "$in_section" == "true" ]]; then
            # Skip comments and blank lines
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ "$line" =~ ^[[:space:]]*$ ]] && continue

            # If we previously found a nested key, look for "    name: value"
            if [[ "$found_key" == "true" ]]; then
                if [[ "$line" =~ ^[[:space:]]{4,}name:[[:space:]]+(.+) ]]; then
                    local value="${BASH_REMATCH[1]}"
                    value="${value%%#*}"
                    value="${value## }"
                    value="${value%% }"
                    value="${value#\"}"
                    value="${value%\"}"
                    value="${value#\'}"
                    value="${value%\'}"
                    echo "$value"
                    return 0
                fi
                # If we hit another 2-space key, the nested block ended without a name
                if [[ "$line" =~ ^[[:space:]]{2}[a-zA-Z] && ! "$line" =~ ^[[:space:]]{4} ]]; then
                    found_key=false
                fi
            fi

            # Match "  key: value" (flat format)
            if [[ "$line" =~ ^[[:space:]]+${key}:[[:space:]]+(.+) ]]; then
                local value="${BASH_REMATCH[1]}"
                # Strip quotes and trailing comments
                value="${value%%#*}"
                value="${value## }"
                value="${value%% }"
                value="${value#\"}"
                value="${value%\"}"
                value="${value#\'}"
                value="${value%\'}"
                echo "$value"
                return 0
            fi
            # Match "  key:" (nested format — value is on subsequent lines)
            if [[ "$line" =~ ^[[:space:]]+${key}:[[:space:]]*$ ]]; then
                found_key=true
            fi
        fi
    done < "$yaml_file"
    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# _validate_name <name> [level]
#
# Validate a machine identifier (principal, agent, repo name).
# level: principal (default), agent, repo
# Pattern: [a-z0-9][a-z0-9_-]*, max 32 chars
# Leading digits allowed by design (e.g., "3d-renderer").
# Reserved names (principal/agent): system, shared, all, default
# Note: _ is already rejected by the regex (must start with [a-z0-9]).
# ─────────────────────────────────────────────────────────────────────────────
_validate_name() {
    local name="$1"
    local level="${2:-principal}"

    # Reject empty
    [[ -z "$name" ]] && { echo "Name cannot be empty" >&2; return 1; }
    # Reject path traversal
    [[ "$name" == *".."* || "$name" == *"/"* ]] && { echo "Name contains path traversal" >&2; return 1; }
    # Reject too long
    [[ ${#name} -gt 32 ]] && { echo "Name exceeds 32 characters" >&2; return 1; }
    # Pattern check
    [[ "$name" =~ ^[a-z0-9][a-z0-9_-]*$ ]] || { echo "Name must match [a-z0-9][a-z0-9_-]*" >&2; return 1; }
    # Reject reserved (principal and agent levels)
    if [[ "$level" == "principal" || "$level" == "agent" ]]; then
        case "$name" in
            system|shared|all|default) echo "Name '$name' is reserved" >&2; return 1 ;;
        esac
    fi
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# _validate_timezone <tz>
#
# Validate a timezone string (e.g., "America/New_York", "UTC", "US/Pacific").
# Pattern: [A-Za-z0-9/_+-]{1,64}
# ─────────────────────────────────────────────────────────────────────────────
_validate_timezone() {
    local tz="$1"
    [[ -z "$tz" ]] && { echo "Timezone cannot be empty" >&2; return 1; }
    [[ ${#tz} -gt 64 ]] && { echo "Timezone exceeds 64 characters" >&2; return 1; }
    [[ "$tz" =~ ^[A-Za-z0-9/_+-]+$ ]] || { echo "Timezone must match [A-Za-z0-9/_+-]+" >&2; return 1; }
    return 0
}

# Main resolution
_pr_resolve() {
    # Find project root
    local script_dir="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}")" && pwd)}"
    AGENCY_PROJECT_ROOT="$(_pr_find_root "$script_dir")" || {
        AGENCY_PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-.}"
    }

    local yaml="$AGENCY_PROJECT_ROOT/agency/config/agency.yaml"

    # ALWAYS resolve principal from agency.yaml via $USER.
    # Never trust a pre-set AGENCY_PRINCIPAL — it leaks from test suites,
    # shell profiles (add-principal wrote it to .zshrc), and old tool runs.
    # AGENCY_PRINCIPAL is effectively deprecated as an input; we still set it
    # as an output for backward compatibility with tools that read it.
    if [[ -f "$yaml" ]]; then
        # Try mapping current $USER
        AGENCY_PRINCIPAL="$(_pr_yaml_get "principals" "${USER:-}" "$yaml" 2>/dev/null)" || {
            # Fall back to "default" mapping
            AGENCY_PRINCIPAL="$(_pr_yaml_get "principals" "default" "$yaml" 2>/dev/null)" || {
                AGENCY_PRINCIPAL="${USER:-unknown}"
            }
        }
    else
        AGENCY_PRINCIPAL="${USER:-unknown}"
    fi

    # Set derived paths
    AGENCY_PRINCIPAL_DIR="$AGENCY_PROJECT_ROOT/usr/$AGENCY_PRINCIPAL"
    AGENCY_REFS_DIR="$AGENCY_PRINCIPAL_DIR/claude/refs"
}

# Run resolution on source
_pr_resolve

# Export for subshells
export AGENCY_PRINCIPAL AGENCY_PRINCIPAL_DIR AGENCY_REFS_DIR AGENCY_PROJECT_ROOT 2>/dev/null || true
