#!/usr/bin/env bash
# What Problem: Agents copy files across worktree boundaries using raw cp,
# bypassing git, creating dirty state, and losing change tracking. This is
# a framework-level problem — any agency with worktrees will hit it.
#
# How & Why: Wraps cp with worktree boundary validation. Resolves the real
# paths of source and destination, checks they're in the same worktree (or
# both in the main checkout). Blocks cross-worktree copies (within one
# repo). For syncing between worktrees, use /worktree-sync instead.
#
# Cross-REPO copies (e.g., monofolk → the-agency upstream-port) are legitimate
# but distinct from cross-worktree. They require an explicit --cross-repo
# flag so they're visible in the audit trail.
#
# Usage: ./agency/tools/cp-safe <source> <dest>
#        ./agency/tools/cp-safe -r <source-dir> <dest-dir>
#        ./agency/tools/cp-safe --cross-repo <source> <peer-repo-dest>
#
# Written: 2026-04-14 during captain session (worktree discipline enforcement)
# QG: fixed multi-source drop (#4), non-existent dest bypass (#2)
# 2026-04-20: added --cross-repo flag for peer-repo workflows (agency#361)

set -euo pipefail

if [[ $# -lt 2 ]]; then
    echo "Usage: cp-safe [-r] [--cross-repo] <source> <dest>" >&2
    echo "  Copies files within the same worktree. Blocks cross-worktree copies." >&2
    echo "  For syncing between worktrees, use /worktree-sync." >&2
    echo "  For cross-repo ports (e.g., monofolk → the-agency), pass --cross-repo." >&2
    exit 1
fi

# Collect flags and positional arguments
CP_FLAGS=()
POSITIONALS=()
CROSS_REPO=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cross-repo)
            CROSS_REPO=true
            shift
            ;;
        -r|-R|--recursive|-a)
            CP_FLAGS+=("$1")
            shift
            ;;
        -*)
            CP_FLAGS+=("$1")
            shift
            ;;
        *)
            POSITIONALS+=("$1")
            shift
            ;;
    esac
done

# Must have exactly 2 positional args (source + dest)
# Multi-source copy (cp file1 file2 dir/) is explicitly not supported —
# use multiple cp-safe calls instead
if [[ ${#POSITIONALS[@]} -ne 2 ]]; then
    echo "Error: exactly one source and one destination required." >&2
    echo "  Got ${#POSITIONALS[@]} positional argument(s)." >&2
    echo "  For multiple files, run cp-safe once per file." >&2
    exit 1
fi

SOURCE="${POSITIONALS[0]}"
DEST="${POSITIONALS[1]}"

# Resolve to absolute paths
resolve_path() {
    local path="$1"
    if [[ "$path" = /* ]]; then
        echo "$path"
    else
        echo "$PWD/$path"
    fi
}

SOURCE_ABS=$(resolve_path "$SOURCE")
DEST_ABS=$(resolve_path "$DEST")

# Get the worktree root for a path
# For non-existent dest, walk up to the nearest existing parent
get_worktree_root() {
    local path="$1"
    local dir

    # If path exists, start from it (or its parent if it's a file)
    if [[ -e "$path" ]]; then
        if [[ -f "$path" ]]; then
            dir=$(dirname "$path")
        else
            dir="$path"
        fi
    else
        # Path doesn't exist — walk up to nearest existing parent
        dir="$path"
        while [[ ! -d "$dir" && "$dir" != "/" ]]; do
            dir=$(dirname "$dir")
        done
    fi

    while [[ "$dir" != "/" ]]; do
        if [[ -e "$dir/.git" ]]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

SOURCE_ROOT=$(get_worktree_root "$SOURCE_ABS" 2>/dev/null || true)
DEST_ROOT=$(get_worktree_root "$DEST_ABS" 2>/dev/null || true)

# BOTH must be in a git tree. If either is outside, block it.
# This prevents copies to /tmp or other non-repo locations from bypassing checks.
if [[ -z "$SOURCE_ROOT" ]]; then
    echo "BLOCKED: Source is not in a git repository." >&2
    echo "  Source: $SOURCE_ABS" >&2
    exit 1
fi

if [[ -z "$DEST_ROOT" ]]; then
    echo "BLOCKED: Destination is not in a git repository." >&2
    echo "  Dest: $DEST_ABS" >&2
    exit 1
fi

# Distinguish cross-worktree (same repo, different checkout) from cross-repo
# (entirely separate repo). A cross-worktree dest lives under the source
# repo's .claude/worktrees/ tree; a cross-repo dest doesn't.
is_cross_worktree_same_repo() {
    # If DEST_ROOT is under SOURCE_ROOT's .claude/worktrees/, it's a
    # sibling worktree of the same repo. Same check symmetric on SOURCE.
    [[ "$DEST_ROOT" = "$SOURCE_ROOT"/.claude/worktrees/* ]] && return 0
    [[ "$SOURCE_ROOT" = "$DEST_ROOT"/.claude/worktrees/* ]] && return 0
    return 1
}

if [[ "$SOURCE_ROOT" != "$DEST_ROOT" ]]; then
    if is_cross_worktree_same_repo; then
        # Same repo, different worktree — the original discipline holds.
        echo "BLOCKED: Cross-worktree copy detected (same repo)." >&2
        echo "  Source:  $SOURCE_ABS (worktree: $SOURCE_ROOT)" >&2
        echo "  Dest:    $DEST_ABS (worktree: $DEST_ROOT)" >&2
        echo "" >&2
        echo "Use /worktree-sync to sync between worktrees, or Write/Edit tools." >&2
        exit 1
    fi

    # Cross-repo — legitimate for upstream-port / peer-repo workflows,
    # but requires explicit --cross-repo flag for audit trail visibility.
    if [[ "$CROSS_REPO" != "true" ]]; then
        echo "BLOCKED: Cross-repo copy detected (different git repositories)." >&2
        echo "  Source:  $SOURCE_ABS (repo: $SOURCE_ROOT)" >&2
        echo "  Dest:    $DEST_ABS (repo: $DEST_ROOT)" >&2
        echo "" >&2
        echo "Cross-repo copies are allowed for upstream-port and peer-repo workflows," >&2
        echo "but require the --cross-repo flag so they're explicit in the audit trail:" >&2
        echo "" >&2
        echo "  ./agency/tools/cp-safe --cross-repo ${CP_FLAGS[*]:-} \"$SOURCE\" \"$DEST\"" >&2
        exit 1
    fi

    # --cross-repo passed — allow + emit audit note
    if [[ ${#CP_FLAGS[@]} -gt 0 ]]; then
        cp "${CP_FLAGS[@]}" "$SOURCE" "$DEST"
    else
        cp "$SOURCE" "$DEST"
    fi
    echo "✓ Cross-repo copy: $(basename "$SOURCE_ROOT") → $(basename "$DEST_ROOT")"
    exit 0
fi

# Same worktree — allow the copy
if [[ ${#CP_FLAGS[@]} -gt 0 ]]; then
    cp "${CP_FLAGS[@]}" "$SOURCE" "$DEST"
else
    cp "$SOURCE" "$DEST"
fi
echo "✓ Copied within $(basename "$SOURCE_ROOT")"
