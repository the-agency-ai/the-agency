#!/usr/bin/env bash
# What Problem: Captain can merge a PR successfully and then forget to run
# /pr-captain-post-merge (which cuts the release tag). 2026-04-21 incident
# (issue #372): 8 PRs merged to main without any release tag between
# 00:50–01:51 UTC. Fix A (pr-merge advisory nag) reduces the failure rate
# but is discipline-dependent — captain can still forget with the advisory
# on screen. Fix B (this tool) makes it structural: while a merge-to-main
# is unreconciled, new-work captain skills refuse until post-merge runs.
#
# How & Why: State file at agency/config/post-merge-pending.json (gitignored,
# per-checkout ephemeral state). Three operations: set (after pr-merge),
# clear (after pr-captain-post-merge verifies release created), check (used
# by new-work skills like /pr-captain-merge, /captain-release, /pr-captain-land).
#
# Reconciliation skills (/captain-sync-all, /pr-captain-post-merge) do NOT
# refuse when pending — they're the path that CLEARS the pending state.
#
# Written: 2026-04-21 during C#372 Fix B of the 4-fix stack (A+B+C+D).
# Companion: pr-merge (Fix A) sets state; pr-captain-post-merge skill
# clears state on successful release view. Skills refuse via
# `post-merge-state check`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

STATE_FILE="$PROJECT_ROOT/agency/config/post-merge-pending.json"
TOOL_VERSION="1.1.0-20260421-c372-fix-b-qg"

# Source helpers if available
[[ -f "$SCRIPT_DIR/lib/_log-helper" ]] && source "$SCRIPT_DIR/lib/_log-helper"
if [[ -f "$SCRIPT_DIR/lib/_colors" ]]; then
    source "$SCRIPT_DIR/lib/_colors"
else
    RED="" GREEN="" YELLOW="" BLUE="" NC=""
fi

usage() {
    cat <<'USAGE'
post-merge-state — Captain's pending-post-merge state tracker (C#372 Fix B)

Usage:
  post-merge-state set <pr-number> <base-ref>
  post-merge-state clear <pr-number> [--force]
  post-merge-state check              # exit 0 clean, exit 1 pending
  post-merge-state get                # print JSON (empty if none pending)
  post-merge-state --help | -h
  post-merge-state --version

Operations:
  set <pr-number> <base-ref>
      Record that PR <pr-number> merged to <base-ref>. Called by pr-merge
      on successful merge to main/master. Overwrites any prior state
      (another pending would already have blocked this merge). Atomic
      (tmp + mv rename).

  clear <pr-number> [--force]
      Clear pending state for PR <pr-number>. Called by
      /pr-captain-post-merge skill after the GitHub release is verified
      via `gh release view`. Safe if already clear (idempotent).
      By default refuses if current state is for a different PR number.
      Pass --force to override the refusal (recovery path for stuck state
      — e.g. PR closed without merge, or state written by a lost session).

  check
      Exit 0 if no pending post-merge; exit 1 if pending. Machine-readable:
      used by /pr-captain-merge, /captain-release, /pr-captain-land as a
      pre-flight gate. Human-readable message on stderr when pending.

  get
      Print the current state as JSON (or "{}" if nothing pending).

State file: agency/config/post-merge-pending.json (gitignored).
Single-PR state — two parallel pending merges would already have been blocked.

Recovery (stuck state):
  1. ./agency/tools/post-merge-state get     — inspect current state
  2. ./agency/tools/post-merge-state clear <pr> --force    — bypass race guard
     OR: rm agency/config/post-merge-pending.json          — last resort

Exit codes:
  0 — operation succeeded (check: no pending)
  1 — check returned pending (not an error — a signal)
  2 — bad usage or bad args, OR corrupt state file, OR refused clear
USAGE
}

die() { echo "${RED}[ERROR]${NC} $*" >&2; exit 2; }

# ISO-8601 UTC timestamp
now_utc() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

# QG fix: shared helper for reading a field from the state file. Returns
# the value to stdout, or empty string if the file is missing. Emits
# "CORRUPT" + non-zero exit if the file exists but cannot be parsed —
# callers decide whether that is fatal (clear: yes) or a soft warning
# (check/get: still show something human-readable).
_read_state_field() {
    local field="$1"
    if [[ ! -f "$STATE_FILE" ]]; then
        return 0  # nothing to read — caller handles empty
    fi
    python3 - "$STATE_FILE" "$field" <<'PY' 2>/dev/null
import json, sys
path, field = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        data = json.load(f)
except Exception:
    # Corrupt state file — signal via exit 3 so caller can distinguish.
    sys.exit(3)
v = data.get(field, "")
print(v)
PY
}

cmd_set() {
    local pr_number="$1"
    local base_ref="$2"

    [[ "$pr_number" =~ ^[0-9]+$ ]] || die "PR number must be integer (got: $pr_number)"
    [[ -n "$base_ref" ]] || die "base-ref required"
    # QG security F-2: validate base_ref shape so hostile input can't
    # break the JSON or inject path chars. Standard git branch-ref
    # character set: alnum, /, _, ., -.
    [[ "$base_ref" =~ ^[a-zA-Z0-9/_.-]+$ ]] || die "base-ref has invalid characters: $base_ref"

    mkdir -p "$(dirname "$STATE_FILE")"

    # QG fix (reviewer-code #8): atomic write via tmp + rename. Prevents
    # a concurrent reader from seeing a half-written file during the
    # cat >"$STATE_FILE" heredoc expansion.
    local tmp="${STATE_FILE}.tmp.$$"
    cat >"$tmp" <<EOF
{
  "schema_version": 1,
  "pr_number": $pr_number,
  "base_ref": "$base_ref",
  "merged_at": "$(now_utc)",
  "tool_version": "$TOOL_VERSION"
}
EOF
    mv -f "$tmp" "$STATE_FILE"
    echo "${GREEN}✓${NC} post-merge state set: PR #$pr_number on $base_ref"
}

cmd_clear() {
    local pr_number="$1"
    local force="${2:-}"
    [[ "$pr_number" =~ ^[0-9]+$ ]] || die "PR number must be integer (got: $pr_number)"

    if [[ ! -f "$STATE_FILE" ]]; then
        # Idempotent: clearing nothing is fine
        echo "${BLUE}(no pending state to clear)${NC}"
        return 0
    fi

    # QG fix (reviewer-code #7): read the pending PR and distinguish
    # three cases: (a) parse succeeds → compare PR numbers; (b) parse
    # fails (exit 3 from helper) → DIE, don't silently clear; (c) no file
    # → handled above.
    local current_pr
    set +e
    current_pr=$(_read_state_field "pr_number")
    local rc=$?
    set -e

    if [[ "$rc" -eq 3 ]]; then
        if [[ "$force" == "--force" ]]; then
            echo "${YELLOW}[warn]${NC} state file is corrupt — --force given, removing anyway" >&2
            rm -f "$STATE_FILE"
            echo "${GREEN}✓${NC} corrupted post-merge state cleared"
            return 0
        fi
        die "state file exists but cannot be parsed — refusing to clear. Inspect with: cat $STATE_FILE ; or recover with: post-merge-state clear $pr_number --force"
    fi

    if [[ -n "$current_pr" && "$current_pr" != "$pr_number" ]]; then
        if [[ "$force" == "--force" ]]; then
            echo "${YELLOW}[warn]${NC} pending state is for PR #$current_pr, --force given, clearing anyway" >&2
        else
            die "pending state is for PR #$current_pr, refusing to clear for PR #$pr_number (would unblock unrelated work). Pass --force to override."
        fi
    fi

    rm -f "$STATE_FILE"
    echo "${GREEN}✓${NC} post-merge state cleared: PR #$pr_number"
}

cmd_check() {
    if [[ ! -f "$STATE_FILE" ]]; then
        return 0  # no pending
    fi

    # QG fix: if the state file is corrupt, treat as pending with
    # unknown-PR message. Don't silently pass — captain must investigate.
    local pr_number base_ref
    set +e
    pr_number=$(_read_state_field "pr_number")
    local rc=$?
    set -e
    if [[ "$rc" -eq 3 ]]; then
        echo "${RED}[post-merge-corrupt]${NC} state file exists but cannot be parsed — refusing to mark clean." >&2
        echo "  Inspect: cat $STATE_FILE" >&2
        echo "  Recover: post-merge-state clear <pr> --force  (if you know the PR)" >&2
        echo "      or:  rm $STATE_FILE  (last resort)" >&2
        return 1
    fi

    base_ref=$(_read_state_field "base_ref")
    : "${pr_number:=?}"
    : "${base_ref:=?}"

    echo "${YELLOW}[post-merge-pending]${NC} PR #$pr_number on $base_ref — post-merge has not run yet." >&2
    echo "  Run: ${GREEN}/pr-captain-post-merge $pr_number${NC}" >&2
    echo "  (C#372 Fix B — new-work captain skills refuse until this completes.)" >&2
    return 1
}

cmd_get() {
    if [[ ! -f "$STATE_FILE" ]]; then
        echo "{}"
        return 0
    fi
    cat "$STATE_FILE"
}

# --- Main ---
[[ $# -lt 1 ]] && { usage >&2; die "Missing subcommand"; }

case "$1" in
    --help|-h)  usage; exit 0 ;;
    --version)  echo "post-merge-state $TOOL_VERSION"; exit 0 ;;
    set)
        shift
        [[ $# -ne 2 ]] && die "set requires: <pr-number> <base-ref>"
        cmd_set "$1" "$2"
        ;;
    clear)
        shift
        # Accept: clear <pr> | clear <pr> --force | clear --force <pr>
        # (no `local` here — we're in the top-level case, not a function)
        force_flag=""
        pr_arg=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --force) force_flag="--force"; shift ;;
                *)       pr_arg="$1"; shift ;;
            esac
        done
        [[ -z "$pr_arg" ]] && die "clear requires: <pr-number> [--force]"
        cmd_clear "$pr_arg" "$force_flag"
        ;;
    check)
        cmd_check
        ;;
    get)
        cmd_get
        ;;
    *)
        die "unknown subcommand: $1 (run --help)"
        ;;
esac
