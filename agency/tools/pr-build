#!/usr/bin/env bash
#
# pr-build — Build PR branches using no-squash merge (preserves full commit history)
#
# What Problem: The old pr-rebuild squashed all commits into a single commit,
# destroying the iteration history that agents and git-bisect need. This tool
# creates PR branches from origin's main branch and merges source branches
# with --no-ff, preserving every individual commit.
#
# How & Why: Use `git merge --no-ff` instead of `git merge --squash`. The merge
# commit is the only new commit on the PR branch — all source commits ride through
# as full history. GitHub renders individual commits in the PR's Commits tab.
# Scope filtering is implicit: the worktree branch IS the scope. No pr-scopes.json
# needed for workstream PRs.
#
# Enforcement Triangle: Tool (this) / Skill (/pr-prep, /ship) / Hookify (block-raw-git-merge-master)
#
# Written: 2026-04-09 during captain session — Day 6, no-squash PR workflow
# Updated: 2026-04-11 — MAR review fixes (main/master detection, input validation,
#   cleanup trap, error handling, dead code removal)
#
# Usage:
#   pr-build <branch-name> <source-branch>     Build a single PR branch
#   pr-build --captain <branch-name>           Build captain PR (source: main branch)
#   pr-build --help                            Show this help

TOOL_VERSION="1.1.0-20260411"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -f "$SCRIPT_DIR/lib/_log-helper" ]]; then
    source "$SCRIPT_DIR/lib/_log-helper"
fi

# Colors
if [[ -f "$SCRIPT_DIR/lib/_colors" ]]; then
    source "$SCRIPT_DIR/lib/_colors"
else
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' BLUE='\033[0;34m' NC='\033[0m'
fi

# ─── Main branch detection ──────────────────────────────────────────────────
# Detect whether the repo uses 'main' or 'master' as default branch.
# Same pattern as worktree-sync (bug #65 fix).
detect_main_branch() {
    local branch
    # Try symbolic ref first (most reliable)
    branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||') || true
    if [[ -n "$branch" ]]; then
        echo "$branch"
        return
    fi
    # Fallback: check which exists
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
        echo "main"
    elif git rev-parse --verify origin/master >/dev/null 2>&1; then
        echo "master"
    else
        echo "main"  # default assumption
    fi
}

MAIN_BRANCH=""

# ─── Input validation ────────────────────────────────────────────────────────
validate_branch_name() {
    local name="$1"
    local label="$2"
    if [[ -z "$name" ]]; then
        echo -e "${RED}ERROR:${NC} $label cannot be empty." >&2
        exit 1
    fi
    if [[ "$name" =~ ^- ]]; then
        echo -e "${RED}ERROR:${NC} $label cannot start with '-': $name" >&2
        exit 1
    fi
    if ! [[ "$name" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
        echo -e "${RED}ERROR:${NC} $label contains invalid characters: $name" >&2
        echo "  Allowed: letters, digits, dots, underscores, slashes, hyphens" >&2
        exit 1
    fi
}

# ─── Cleanup trap ────────────────────────────────────────────────────────────
_original_branch=""

_cleanup() {
    if [[ -n "$_original_branch" ]]; then
        git checkout "$_original_branch" >/dev/null 2>&1 || true
    fi
}

trap _cleanup EXIT

# ─── Help ────────────────────────────────────────────────────────────────────
_help() {
    cat <<EOF
pr-build — Build PR branches with full commit history (no squash)

Version: $TOOL_VERSION

Usage:
  pr-build <branch-name> <source-branch>     Build a single PR branch
  pr-build --captain <branch-name>           Build captain PR (source: main branch)
  pr-build --help                            Show this help

Examples:
  pr-build jordan-folio-D6-R3 folio          Merge folio branch into PR branch
  pr-build --captain jordan-captain-D6-R1    Merge main into captain PR branch

The PR branch is created from origin's main branch and the source branch is
merged with --no-ff, preserving all individual commits.

Day-Release naming: {principal}-{agent}-D{day}-R{release}
  Day = Nth day the principal has made PRs (not calendar day)
  Release = Nth PR by this principal on this day (across all agents)
EOF
}

# ─── Preconditions ───────────────────────────────────────────────────────────
_preconditions() {
    # Detect main branch
    MAIN_BRANCH=$(detect_main_branch)

    local current_branch
    current_branch=$(git rev-parse --abbrev-ref HEAD)
    if [[ "$current_branch" != "$MAIN_BRANCH" ]]; then
        echo -e "${RED}ERROR:${NC} Must be on $MAIN_BRANCH (currently on: $current_branch)" >&2
        exit 1
    fi

    if [[ -n "$(git status --porcelain)" ]]; then
        echo -e "${RED}ERROR:${NC} Working tree is not clean. Commit or stash changes first." >&2
        exit 1
    fi

    # Ensure origin's main branch is available
    if ! git rev-parse "origin/$MAIN_BRANCH" >/dev/null 2>&1; then
        echo -e "${RED}ERROR:${NC} origin/$MAIN_BRANCH not found. Run: git fetch origin" >&2
        exit 1
    fi

    _original_branch="$MAIN_BRANCH"
}

# ─── Build ───────────────────────────────────────────────────────────────────
build_pr_branch() {
    local pr_branch="$1"
    local source_branch="$2"
    local is_captain="${3:-false}"

    local RUN_ID
    RUN_ID=$(log_start "pr-build" "$pr_branch" "$source_branch" 2>/dev/null) || true

    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  pr-build${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  PR Branch:  $pr_branch"
    echo "  Source:     $source_branch"
    echo "  Base:       origin/$MAIN_BRANCH"
    if [[ "$is_captain" == "true" ]]; then
        echo "  Mode:       captain ($MAIN_BRANCH catch-up)"
    fi
    echo ""

    # Verify source branch exists
    if ! git rev-parse "$source_branch" >/dev/null 2>&1; then
        echo -e "${RED}ERROR:${NC} Source branch '$source_branch' not found." >&2
        log_end "$RUN_ID" "error" "1" "0" "source branch not found: $source_branch" 2>/dev/null || true
        exit 1
    fi

    # Check if source has commits ahead of origin's main branch
    local ahead_count
    ahead_count=$(git rev-list --count "origin/$MAIN_BRANCH..$source_branch")
    if [[ "$ahead_count" -eq 0 ]]; then
        echo -e "${YELLOW}SKIP:${NC} $source_branch has 0 commits ahead of origin/$MAIN_BRANCH. Nothing to PR."
        log_end "$RUN_ID" "skip" "0" "0" "0 commits ahead" 2>/dev/null || true
        return 0
    fi

    # Delete existing PR branch if it exists
    if git rev-parse "$pr_branch" >/dev/null 2>&1; then
        echo -e "${YELLOW}  Deleting existing branch: $pr_branch${NC}"
        if ! git branch -D "$pr_branch" 2>&1; then
            echo -e "${RED}ERROR:${NC} Could not delete existing branch '$pr_branch' (may be checked out in a worktree)." >&2
            log_end "$RUN_ID" "error" "1" "0" "could not delete existing branch" 2>/dev/null || true
            exit 1
        fi
    fi

    # Create PR branch from origin's main branch
    echo -e "  Creating branch from origin/$MAIN_BRANCH..."
    if ! git checkout -b "$pr_branch" "origin/$MAIN_BRANCH" 2>&1; then
        echo -e "${RED}ERROR:${NC} Could not create branch '$pr_branch' from origin/$MAIN_BRANCH." >&2
        log_end "$RUN_ID" "error" "1" "0" "could not create PR branch" 2>/dev/null || true
        exit 1
    fi

    # Merge source with --no-ff (preserves all commits)
    echo -e "  Merging $source_branch (--no-ff, preserving $ahead_count commits)..."
    local merge_msg="Merge $source_branch into $pr_branch

No-squash merge — preserves full commit history.
$ahead_count commits from $source_branch."

    # Merge commits are detected by commit-precheck (MERGE_HEAD check) and
    # skip pre-commit validation — the worktree agent's QG already validated
    # the content. No --no-verify needed.
    if ! git merge --no-ff "$source_branch" -m "$merge_msg" 2>&1; then
        echo -e "${RED}ERROR:${NC} Merge conflict!" >&2
        echo "  Conflicts in:" >&2
        git diff --name-only --diff-filter=U 2>/dev/null | head -20 >&2
        echo "" >&2
        echo "  Aborting merge and returning to $MAIN_BRANCH." >&2
        git merge --abort 2>/dev/null || true
        git checkout "$MAIN_BRANCH" >/dev/null 2>&1
        log_end "$RUN_ID" "error" "1" "0" "merge conflict" 2>/dev/null || true
        exit 1
    fi

    # Stats
    local commit_count diff_summary
    commit_count=$(git rev-list --count "origin/$MAIN_BRANCH..$pr_branch")
    diff_summary=$(git diff --stat "origin/$MAIN_BRANCH" 2>/dev/null | tail -1)

    # Return to main branch
    git checkout "$MAIN_BRANCH" >/dev/null 2>&1

    echo ""
    echo -e "${GREEN}  Built: $pr_branch${NC}"
    echo "  Commits: $commit_count (including merge commit)"
    echo "  $diff_summary"
    echo ""

    log_end "$RUN_ID" "success" "0" "0" "built $pr_branch: $commit_count commits" 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --help|-h)
        _help
        exit 0
        ;;
    --version|-v)
        echo "pr-build $TOOL_VERSION"
        exit 0
        ;;
    --captain)
        shift
        pr_branch="${1:-}"
        if [[ -z "$pr_branch" ]]; then
            echo "Usage: pr-build --captain <branch-name>" >&2
            exit 1
        fi
        validate_branch_name "$pr_branch" "PR branch name"
        _preconditions
        build_pr_branch "$pr_branch" "$MAIN_BRANCH" "true"
        ;;
    "")
        echo "Usage: pr-build <branch-name> <source-branch>" >&2
        echo "       pr-build --captain <branch-name>" >&2
        echo "       pr-build --help" >&2
        exit 1
        ;;
    *)
        pr_branch="$1"
        source_branch="${2:-}"
        if [[ -z "$source_branch" ]]; then
            echo "Usage: pr-build <branch-name> <source-branch>" >&2
            exit 1
        fi
        validate_branch_name "$pr_branch" "PR branch name"
        validate_branch_name "$source_branch" "Source branch name"
        _preconditions
        build_pr_branch "$pr_branch" "$source_branch" "false"
        ;;
esac
