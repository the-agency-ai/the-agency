#!/bin/bash
# Manage iOS Simulator
# Usage: ./tools/simulator [list|boot|open] [device-name]

set -e

ACTION="${1:-list}"
DEVICE="${2:-iPhone 15 Pro}"

case "$ACTION" in
    list)
        echo "Available simulators:"
        xcrun simctl list devices available
        ;;
    boot)
        echo "Booting $DEVICE..."
        xcrun simctl boot "$DEVICE" 2>/dev/null || echo "Already booted or not found"
        ;;
    open)
        echo "Opening Simulator..."
        open -a Simulator
        ;;
    screenshot)
        TIMESTAMP=$(date +%Y%m%d_%H%M%S)
        OUTPUT="${3:-screenshot_$TIMESTAMP.png}"
        echo "Taking screenshot..."
        xcrun simctl io booted screenshot "$OUTPUT"
        echo "Saved: $OUTPUT"
        ;;
    *)
        echo "Usage: ./tools/simulator [list|boot|open|screenshot] [device-name]"
        exit 1
        ;;
esac
