{
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR\"/claude/tools/statusline.sh"
  },
  "hooks": {
    "SessionStart": [],
    "SessionEnd": [],
    "UserPromptSubmit": [],
    "PreToolUse": [],
    "PostToolUse": [],
    "PermissionRequest": [],
    "TaskCompleted": [],
    "Stop": [],
    "Notification": []
  },
  "enabledPlugins": {
    "hookify@claude-plugins-official": false
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(**)",
      "Edit(/tmp/**)",
      "Edit(/var/folders/**)",
      "Read(**)",
      "Read(/tmp/**)",
      "Read(/var/folders/**)",
      "Write(**)",
      "Write(/tmp/**)",
      "Write(/var/folders/**)"
    ]
  }
}
